From 0a3e7caeff2258dadfccb5ab688c2447ecda2736 Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Fri, 17 Jul 2026 14:54:32 +0200
Subject: [PATCH 114/131] iommu: sun50i: A523: translate the VPU masters
 (VE0/VE1, bits 2-3)

The A523 variant keeps the BSP opt-in bypass scheme: every master is
bypassed except those that carry iommus= in the DT. Clear bits 2-3 so
the cedar VE's two master ports get translated, matching the new
iommus = <&iommu 2>, <&iommu 3> in the ve node.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 drivers/iommu/sun50i-iommu.c | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/drivers/iommu/sun50i-iommu.c b/drivers/iommu/sun50i-iommu.c
index 50c8ab360..08f47e744 100644
--- a/drivers/iommu/sun50i-iommu.c
+++ b/drivers/iommu/sun50i-iommu.c
@@ -1300,12 +1300,12 @@ static const struct sun50i_iommu_variant sun55i_a523_variant = {
 	/* v15 = 7 masters: sunxi_tlb_flush escribe 0x0003007f (bit 6 = DI) */
 	.tlb_flush_micro = GENMASK(6, 0),
 	/*
-	 * BSP DEFAULT_BYPASS_VALUE 0x7f con opt-in por master: solo el DE
-	 * (master 5, el unico con iommus= en el DTS) se traduce. Al portar
-	 * VPU (VE0/VE1 bits 2-3) o DI (bit 6), limpiar aqui su bit ademas
-	 * de anadir iommus= a su nodo.
+	 * BSP DEFAULT_BYPASS_VALUE 0x7f con opt-in por master: se traducen
+	 * el DE (master 5) y el VPU cedar (VE0/VE1, bits 2-3), los que
+	 * llevan iommus= en el DTS. Al portar DI (bit 6), limpiar aqui su
+	 * bit ademas de anadir iommus= a su nodo.
 	 */
-	.bypass_val = 0x7f & ~BIT(5),
+	.bypass_val = 0x7f & ~(BIT(5) | BIT(3) | BIT(2)),
 	.has_ivld_range = true,
 	.bsp_pte_perms = true,
 };
