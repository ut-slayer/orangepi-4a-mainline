-#define INNO_PLL0_PIX_CLK_BP		GENMASK(2, 2)	/* via clk_div2 byte2 */
+#define INNO_PLL0_PIX_CLK_BP		BIT(1)	/* phy_inno.h: pix_clk_bp es bit1 de 0xA0 (bit2 = prepll_bp) */
 #define INNO_PLL0_PREPLL_DIV		GENMASK(13, 8)
