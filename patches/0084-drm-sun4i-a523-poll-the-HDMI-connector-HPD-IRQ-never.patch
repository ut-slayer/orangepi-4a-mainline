From 115a907a42f20c98d7e015341b9c27af4f832176 Mon Sep 17 00:00:00 2001
From: AurealNix T527 <juanmanuellopezcarrillo@gmail.com>
Date: Tue, 14 Jul 2026 00:16:00 +0200
Subject: [PATCH 084/106] drm/sun4i: a523: poll the HDMI connector (HPD IRQ
 never fires)

With ENHPDRXSENSE enabled read_hpd() now returns the live cable state,
but hotplug still doesn't propagate: the A523's HDMI HPD interrupt never
fires (verified on an OrangePi 4A - the PHY_STAT0 HPD bit tracks the
cable perfectly, 0x01 unplugged / 0xf3 plugged, yet the shared
5520000.hdmi IRQ delivers no HPD event and the connector's cached status
never updates). The Allwinner BSP does not use the HPD interrupt either:
it polls sunxi_hdmi_get_hpd() (== PHY_STAT0.HPD) in a kthread.

dw-hdmi hardcodes connector->polled = DRM_CONNECTOR_POLL_HPD, which tells
the poll helper to rely on that interrupt. Add a poll_hpd plat_data flag
that switches the connector to DRM_CONNECTOR_POLL_CONNECT |
DRM_CONNECTOR_POLL_DISCONNECT so the standard output poll worker samples
read_hpd() instead, and set it for the A523. Boot detection was already
correct (synchronous probe); this adds working hotplug. No other
platform is affected.

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 drivers/gpu/drm/bridge/synopsys/dw-hdmi.c | 10 +++++++++-
 drivers/gpu/drm/sun4i/sun8i_dw_hdmi.c     |  3 +++
 drivers/gpu/drm/sun4i/sun8i_dw_hdmi.h     |  1 +
 include/drm/bridge/dw_hdmi.h              |  6 ++++++
 4 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/bridge/synopsys/dw-hdmi.c b/drivers/gpu/drm/bridge/synopsys/dw-hdmi.c
index defe6f2c2..aef022058 100644
--- a/drivers/gpu/drm/bridge/synopsys/dw-hdmi.c
+++ b/drivers/gpu/drm/bridge/synopsys/dw-hdmi.c
@@ -2585,7 +2585,15 @@ static int dw_hdmi_connector_create(struct dw_hdmi *hdmi)
 		connector->ycbcr_420_allowed = false;
 
 	connector->interlace_allowed = 1;
-	connector->polled = DRM_CONNECTOR_POLL_HPD;
+	/*
+	 * Most platforms deliver hotplug via the HPD interrupt. On platforms
+	 * whose HPD IRQ never fires (poll_hpd), fall back to periodic connector
+	 * polling: read_hpd still returns the live cable state, it just has to
+	 * be sampled by the poll worker rather than an edge interrupt.
+	 */
+	connector->polled = hdmi->plat_data->poll_hpd ?
+		DRM_CONNECTOR_POLL_CONNECT | DRM_CONNECTOR_POLL_DISCONNECT :
+		DRM_CONNECTOR_POLL_HPD;
 
 	drm_connector_helper_add(connector, &dw_hdmi_connector_helper_funcs);
 
diff --git a/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.c b/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.c
index 24b2232f9..681354c88 100644
--- a/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.c
+++ b/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.c
@@ -207,6 +207,7 @@ static int sun8i_dw_hdmi_bind(struct device *dev, struct device *master,
 
 	plat_data->mode_valid = hdmi->quirks->mode_valid;
 	plat_data->use_drm_infoframe = hdmi->quirks->use_drm_infoframe;
+	plat_data->poll_hpd = hdmi->quirks->poll_hpd;
 	sun8i_hdmi_phy_set_ops(hdmi->phy, plat_data);
 
 	platform_set_drvdata(pdev, hdmi);
@@ -275,6 +276,8 @@ static const struct sun8i_dw_hdmi_quirks sun50i_h6_quirks = {
 static const struct sun8i_dw_hdmi_quirks sun55i_a523_quirks = {
 	.mode_valid = sun8i_dw_hdmi_mode_valid_a523,
 	.use_drm_infoframe = true,
+	/* The A523 HPD interrupt never fires; poll the connector instead. */
+	.poll_hpd = true,
 };
 
 static const struct of_device_id sun8i_dw_hdmi_dt_ids[] = {
diff --git a/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.h b/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.h
index 82c3711f3..fc172514e 100644
--- a/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.h
+++ b/drivers/gpu/drm/sun4i/sun8i_dw_hdmi.h
@@ -176,6 +176,7 @@ struct sun8i_dw_hdmi_quirks {
 					   const struct drm_display_info *info,
 					   const struct drm_display_mode *mode);
 	unsigned int use_drm_infoframe : 1;
+	unsigned int poll_hpd : 1;
 };
 
 struct sun8i_dw_hdmi {
diff --git a/include/drm/bridge/dw_hdmi.h b/include/drm/bridge/dw_hdmi.h
index e6a570951..d1f3e9f80 100644
--- a/include/drm/bridge/dw_hdmi.h
+++ b/include/drm/bridge/dw_hdmi.h
@@ -162,6 +162,12 @@ struct dw_hdmi_plat_data {
 			     unsigned long mpixelclock);
 
 	unsigned int disable_cec : 1;
+	/*
+	 * Poll the connector for hotplug instead of relying on the HPD
+	 * interrupt. Set by platforms whose HPD IRQ does not fire (e.g. the
+	 * Allwinner A523/T527, whose BSP polls HPD in a kthread instead).
+	 */
+	unsigned int poll_hpd : 1;
 };
 
 struct dw_hdmi *dw_hdmi_probe(struct platform_device *pdev,
