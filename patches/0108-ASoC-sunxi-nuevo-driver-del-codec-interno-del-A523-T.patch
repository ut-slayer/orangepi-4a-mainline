+/*******************************************************************************
+ * Probe
+ ******************************************************************************/
+
+static const struct regmap_config sun55i_codec_regmap_config = {
+	.reg_bits	= 32,
+	.reg_stride	= 4,
+	.val_bits	= 32,
+	.max_register	= SUNXI_AUDIO_MAX_REG,
+};
+
+static const char * const sun55i_codec_supply_names[] = {
+	"avcc",		/* bias supply, 1.8V (reg_aldo4) */
+	"vdd",		/* module supply, 3.3V (reg_cldo3) */
+	"cpvin",	/* headphone charge pump, 1.8V (reg_cldo1) */
+};
+
+static void sun55i_codec_quiesce_jack(void *data)
+{
+	struct sun55i_codec *scodec = data;
+
+	/* stop the jack machinery before the card goes away */
+	regmap_update_bits(scodec->regmap, SUNXI_HMIC_CTL,
+			   0x1 << JACK_IN_IRQ_EN | 0x1 << JACK_OUT_IRQ_EN |
+			   0x1 << MIC_DET_IRQ_EN, 0);
+	cancel_delayed_work_sync(&scodec->jack.scan_work);
+}
+
+static int sun55i_codec_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct snd_soc_card *card;
+	struct sun55i_codec *scodec;
+	struct sun55i_codec_jack *jack;
+	struct resource *res;
+	void __iomem *base;
+	int ret;
+
+	scodec = devm_kzalloc(dev, sizeof(*scodec), GFP_KERNEL);
+	if (!scodec)
+		return -ENOMEM;
+
+	scodec->dev = dev;
+	mutex_init(&scodec->acf_mutex);
+
+	base = devm_platform_get_and_ioremap_resource(pdev, 0, &res);
+	if (IS_ERR(base))
+		return PTR_ERR(base);
+
+	scodec->regmap = devm_regmap_init_mmio(dev, base,
+					       &sun55i_codec_regmap_config);
+	if (IS_ERR(scodec->regmap))
+		return dev_err_probe(dev, PTR_ERR(scodec->regmap),
+				     "regmap init failed\n");
+
+	/*
+	 * BSP order: pulse the reset ("to avoid register modification
+	 * before module load"), then enable the bus clock.
+	 */
+	scodec->rst = devm_reset_control_get_exclusive(dev, NULL);
+	if (IS_ERR(scodec->rst))
+		return dev_err_probe(dev, PTR_ERR(scodec->rst),
+				     "reset get failed\n");
+	reset_control_assert(scodec->rst);
+	ret = reset_control_deassert(scodec->rst);
+	if (ret)
+		return dev_err_probe(dev, ret, "reset deassert failed\n");
+
+	scodec->clk_bus = devm_clk_get_enabled(dev, "bus");
+	if (IS_ERR(scodec->clk_bus))
+		return dev_err_probe(dev, PTR_ERR(scodec->clk_bus),
+				     "bus clock get failed\n");
+
+	scodec->clk_dac = devm_clk_get(dev, "dac");
+	if (IS_ERR(scodec->clk_dac))
+		return dev_err_probe(dev, PTR_ERR(scodec->clk_dac),
+				     "dac clock get failed\n");
+
+	scodec->clk_adc = devm_clk_get(dev, "adc");
+	if (IS_ERR(scodec->clk_adc))
+		return dev_err_probe(dev, PTR_ERR(scodec->clk_adc),
+				     "adc clock get failed\n");
+
+	ret = devm_regulator_bulk_get_enable(dev,
+				ARRAY_SIZE(sun55i_codec_supply_names),
+				sun55i_codec_supply_names);
+	if (ret)
+		return dev_err_probe(dev, ret, "supplies get failed\n");
+
+	/* External speaker amplifier (OPi4A: PH6, active high) */
+	scodec->gpio_pa = devm_gpiod_get_optional(dev, "allwinner,pa",
+						  GPIOD_OUT_LOW);
+	if (IS_ERR(scodec->gpio_pa))
+		return dev_err_probe(dev, PTR_ERR(scodec->gpio_pa),
+				     "PA GPIO get failed\n");
+
+	/* Jack parameters (OPi4A: level 1, threshold 8, debounce 0) */
+	jack = &scodec->jack;
+	mutex_init(&jack->lock);
+	INIT_DELAYED_WORK(&jack->scan_work, sun55i_codec_jack_scan_work);
+	jack->first_report = true;
+	jack->irq = platform_get_irq_optional(pdev, 0);
+	jack->det_level = !device_property_read_bool(dev,
+					"allwinner,jack-det-level-low");
+	jack->det_threshold = 8;
+	device_property_read_u32(dev, "allwinner,jack-det-threshold",
+				 &jack->det_threshold);
+	jack->det_debounce = 0;
+	device_property_read_u32(dev, "allwinner,jack-det-debounce",
+				 &jack->det_debounce);
+	/* BSP default button windows: hook 0-0, up 2-2, down 4-5, voice 1-1 */
+	jack->key_det_vol[0][0] = 0;
+	jack->key_det_vol[0][1] = 0;
+	jack->key_det_vol[1][0] = 2;
+	jack->key_det_vol[1][1] = 2;
+	jack->key_det_vol[2][0] = 4;
+	jack->key_det_vol[2][1] = 5;
+	jack->key_det_vol[3][0] = 1;
+	jack->key_det_vol[3][1] = 1;
+
+	/* DMA data: FIFOs at +0x20 (DAC) / +0x40 (ADC), MCU DMA req 7,
+	 * maxburst 4 (BSP codec_plat). The bus width is derived from the
+	 * sample format by the generic dmaengine PCM, like the BSP does.
+	 */
+	scodec->playback_dma_data.addr = res->start + SUNXI_DAC_TXDATA;
+	scodec->playback_dma_data.maxburst = SUN55I_CODEC_DMA_MAXBURST;
+	scodec->capture_dma_data.addr = res->start + SUNXI_ADC_RXDATA;
+	scodec->capture_dma_data.maxburst = SUN55I_CODEC_DMA_MAXBURST;
+
+	ret = devm_snd_soc_register_component(dev, &sun55i_codec_codec,
+					      &sun55i_codec_dai, 1);
+	if (ret)
+		return dev_err_probe(dev, ret, "codec register failed\n");
+
+	ret = devm_snd_soc_register_component(dev, &sun55i_codec_cpu_component,
+					      &sun55i_codec_cpu_dai, 1);
+	if (ret)
+		return dev_err_probe(dev, ret, "CPU DAI register failed\n");
+
+	ret = devm_snd_dmaengine_pcm_register(dev, NULL, 0);
+	if (ret)
+		return dev_err_probe(dev, ret, "dmaengine PCM register failed\n");
+
+	card = sun55i_codec_create_card(dev);
+	if (IS_ERR(card))
+		return PTR_ERR(card);
+
+	snd_soc_card_set_drvdata(card, scodec);
+
+	/* make sure the jack work/irq stop before the card is torn down */
+	ret = devm_add_action_or_reset(dev, sun55i_codec_quiesce_jack, scodec);
+	if (ret)
+		return ret;
+
+	ret = devm_snd_soc_register_card(dev, card);
+	if (ret)
+		return dev_err_probe(dev, ret, "card register failed\n");
+
+	return 0;
+}
+
+static const struct of_device_id sun55i_codec_of_match[] = {
+	{ .compatible = "allwinner,sun55i-a523-codec" },
+	{}
+};
+MODULE_DEVICE_TABLE(of, sun55i_codec_of_match);
+
+static struct platform_driver sun55i_codec_driver = {
+	.driver = {
+		.name = "sun55i-a523-codec",
+		.of_match_table = sun55i_codec_of_match,
+	},
+	.probe = sun55i_codec_probe,
+};
+module_platform_driver(sun55i_codec_driver);
+
+MODULE_DESCRIPTION("Allwinner sun55i A523/T527 internal codec driver");
+MODULE_AUTHOR("huhaoxin <huhaoxin@allwinnertech.com>");
+MODULE_LICENSE("GPL");
