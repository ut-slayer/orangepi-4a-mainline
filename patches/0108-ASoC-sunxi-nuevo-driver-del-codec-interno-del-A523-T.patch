+/*
+ * The three mic events share the main mic bias and the ADC digital
+ * enable, refcounted with the acf mutex exactly like the BSP.
+ */
+static int sun55i_codec_mic_event(struct snd_soc_dapm_widget *w,
+				  struct snd_kcontrol *k, int event,
+				  unsigned int an_reg, bool *self,
+				  bool *other1, bool *other2)
+{
+	struct snd_soc_component *component = snd_soc_dapm_to_component(w->dapm);
+	struct sun55i_codec *scodec = snd_soc_card_to_codec(component->card);
+	struct regmap *regmap = scodec->regmap;
+
+	switch (event) {
+	case SND_SOC_DAPM_PRE_PMU:
+		regmap_update_bits(regmap, an_reg,
+				   0x1 << MICx_PGA_EN, 0x1 << MICx_PGA_EN);
+		regmap_update_bits(regmap, an_reg,
+				   0x1 << ADCx_EN, 0x1 << ADCx_EN);
+		mutex_lock(&scodec->acf_mutex);
+		*self = true;
+		if (!*other1 && !*other2) {
+			regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+					   0x1 << MMIC_BIAS_EN,
+					   0x1 << MMIC_BIAS_EN);
+			/* BSP: delay to avoid pop recording at the
+			 * beginning; adc fifo delay time must not be
+			 * less than 20ms.
+			 */
+			msleep(240);
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << ADC_DIG_EN,
+					   0x1 << ADC_DIG_EN);
+		}
+		mutex_unlock(&scodec->acf_mutex);
+		break;
+	case SND_SOC_DAPM_POST_PMD:
+		mutex_lock(&scodec->acf_mutex);
+		*self = false;
+		if (!*other1 && !*other2) {
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << ADC_DIG_EN,
+					   0x0 << ADC_DIG_EN);
+			regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+					   0x1 << MMIC_BIAS_EN,
+					   0x0 << MMIC_BIAS_EN);
+		}
+		mutex_unlock(&scodec->acf_mutex);
+		regmap_update_bits(regmap, an_reg,
+				   0x1 << ADCx_EN, 0x0 << ADCx_EN);
+		regmap_update_bits(regmap, an_reg,
+				   0x1 << MICx_PGA_EN, 0x0 << MICx_PGA_EN);
+		break;
+	default:
+		break;
+	}
+
+	return 0;
+}
+
+static int sun55i_codec_mic1_event(struct snd_soc_dapm_widget *w,
+				   struct snd_kcontrol *k, int event)
+{
+	struct snd_soc_component *component = snd_soc_dapm_to_component(w->dapm);
+	struct sun55i_codec *scodec = snd_soc_card_to_codec(component->card);
+
+	return sun55i_codec_mic_event(w, k, event, SUNXI_ADC1_AN_CTL,
+				      &scodec->mic1, &scodec->mic2,
+				      &scodec->mic3);
+}
