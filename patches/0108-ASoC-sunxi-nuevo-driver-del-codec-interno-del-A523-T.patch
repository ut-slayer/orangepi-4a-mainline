@@ -0,0 +1,1537 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Allwinner sun55i A523/T527 internal audio codec driver
+ *
+ * Faithful mainline port of the Allwinner BSP 5.15 driver
+ * bsp/drivers/sound/platform/snd_sun55iw3_codec.c (v1.0.12) plus the
+ * relevant bits of snd_sunxi_aaudio.c (DMA/FIFO parameters) and
+ * snd_sunxi_jack{,_codec}.c (jack detection state machine).
+ *
+ * Copyright (c) 2022, huhaoxin <huhaoxin@allwinnertech.com> (original BSP)
+ * Copyright (c) 2026, AurealNix port to mainline
+ *
+ * The hardware register programming (routes, gains, init sequences,
+ * jack detection thresholds) is taken verbatim from the BSP, which is
+ * the source of truth for this hardware. The glue (ASoC component,
+ * dmaengine PCM, card creation) follows the mainline sun4i-codec.c
+ * pattern: a single self-contained driver that registers the codec
+ * component, a dummy CPU DAI carrying the DMA data, the generic
+ * dmaengine PCM and its own sound card with pin switches and jack.
+ */
+
+#include <linux/clk.h>
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/input.h>
+#include <linux/interrupt.h>
+#include <linux/io.h>
+#include <linux/ktime.h>
+#include <linux/module.h>
+#include <linux/mutex.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+#include <linux/regmap.h>
+#include <linux/regulator/consumer.h>
+#include <linux/reset.h>
+#include <linux/workqueue.h>
+
+#include <sound/dmaengine_pcm.h>
+#include <sound/jack.h>
+#include <sound/pcm.h>
+#include <sound/pcm_params.h>
+#include <sound/soc.h>
+#include <sound/soc-dapm.h>
+#include <sound/tlv.h>
+
+/*
+ * Register map (BSP snd_sun55iw3_codec.h). Offsets relative to
+ * 0x07110000, block length 0x350 (the BSP declares 0x348 but the last
+ * register SUNXI_POWER_AN_CTL itself sits at 0x348).
+ */
+/* Digital */
+#define SUNXI_DAC_DPC		0x00
+#define SUNXI_DAC_VOL_CTL	0x04
+#define SUNXI_DAC_FIFO_CTL	0x10
+#define SUNXI_DAC_FIFO_STA	0x14
+#define SUNXI_DAC_TXDATA	0x20
+#define SUNXI_DAC_CNT		0x24
+#define SUNXI_DAC_DEBUG		0x28
+#define SUNXI_ADC_FIFO_CTL	0x30
+#define SUNXI_ADC_VOL_CTL1	0x34
+#define SUNXI_ADC_FIFO_STA	0x38
+#define SUNXI_ADC_RXDATA	0x40
+#define SUNXI_ADC_CNT		0x44
+#define SUNXI_ADC_DEBUG		0x4C
+#define SUNXI_ADC_DIG_CTL	0x50
+#define SUNXI_DAC_DAP_CTL	0xF0
+#define SUNXI_ADC_DAP_CTL	0xF8
+#define SUNXI_VERSION		0x2C0
+/* Analog */
+#define SUNXI_ADC1_AN_CTL	0x300
+#define SUNXI_ADC2_AN_CTL	0x304
+#define SUNXI_ADC3_AN_CTL	0x308
+#define SUNXI_DAC_AN_REG	0x310
+#define SUNXI_DAC2_AN_REG	0x314
+#define SUNXI_MICBIAS_AN_CTL	0x318
+#define SUNXI_RAMP		0x31c
+#define SUNXI_BIAS_AN_CTL	0x320
+#define SUNXI_HP_AN_CTL		0x324
+#define SUNXI_HMIC_CTL		0x328
+#define SUNXI_HMIC_STA		0x32C
+#define SUNXI_POWER_AN_CTL	0x348
+#define SUNXI_AUDIO_MAX_REG	SUNXI_POWER_AN_CTL
+
+/* SUNXI_DAC_DPC */
+#define DAC_DIG_EN		31
+#define DVOL			12
+#define HUB_EN			0
+/* SUNXI_DAC_VOL_CTL */
+#define DAC_VOL_SEL		16
+#define DAC_VOL_L		8
+#define DAC_VOL_R		0
+/* SUNXI_DAC_FIFO_CTL */
+#define DAC_FS			29
+#define DAC_FIFO_MODE		24
+#define TX_TRIG_LEVEL		8
+#define DAC_MONO_EN		6
+#define TX_SAMPLE_BITS		5
+#define DAC_DRQ_EN		4
+#define DAC_FIFO_FLUSH		0
+/* SUNXI_DAC_FIFO_STA */
+#define DAC_TXE_INT		3
+#define DAC_TXU_INT		2
+#define DAC_TXO_INT		1
+/* SUNXI_DAC_DEBUG */
+#define DA_SWP			6
+/* SUNXI_ADC_FIFO_CTL */
+#define ADC_FS			29
+#define ADC_DIG_EN		28
+#define ADCFDT			26
+#define ADCDFEN			25
+#define RX_FIFO_MODE		24
+#define RX_SAMPLE_BITS		16
+#define ADC_DRQ_EN		3
+#define ADC_FIFO_FLUSH		0
+/* SUNXI_ADC_VOL_CTL1 */
+#define ADC3_VOL		16
+#define ADC2_VOL		8
+#define ADC1_VOL		0
+/* SUNXI_ADC_FIFO_STA */
+#define ADC_RXA_INT		3
+#define ADC_RXO_INT		1
+/* SUNXI_ADC_DEBUG */
+#define ADC_SWP2		25
+#define ADC_SWP1		24
+/* SUNXI_ADC_DIG_CTL */
+#define ADC3_VOL_EN		17
+#define ADC1_2_VOL_EN		16
+#define ADC_CHANNEL_EN		0
+/* SUNXI_DAC_DAP_CTL */
+#define DDAP_EN			31
+/* SUNXI_ADC_DAP_CTL */
+#define ADAP0_EN		31
+#define ADAP1_EN		27
+/* SUNXI_ADC[123]_AN_CTL (same layout) */
+#define ADCx_EN			31
+#define MICx_PGA_EN		30
+#define ADCx_PGA_GAIN_CTL	8
+/* SUNXI_DAC_AN_REG */
+#define HEADPHONE_GAIN		28
+#define CPLDO_VOLTAGE		24
+#define DACL_EN			15
+#define DACR_EN			14
+#define LINEOUTL_EN		13
+#define LMUTE			12
+#define LINEOUTR_EN		11
+#define RMUTE			10
+#define CPLDO_EN		7
+#define LINEOUT_GAIN		0
+/* SUNXI_MICBIAS_AN_CTL */
+#define SEL_DET_ADC_BF		24
+#define JACK_DET_EN		23
+#define MIC_DET_ADC_EN		20
+#define DET_MODE		18
+#define AUTO_PULL_LOW_EN	17
+#define HMIC_BIAS_EN		15
+#define HMIC_BIAS_SEL		13
+#define MMIC_BIAS_EN		7
+/* SUNXI_BIAS_AN_CTL */
+#define BIASDATA		0
+/* SUNXI_HP_AN_CTL */
+#define HPPA_EN			15
+/* SUNXI_HMIC_CTL */
+#define MDATA_THRESHOLD		16
+#define HMIC_N			6
+#define JACK_OUT_IRQ_EN		2
+#define JACK_IN_IRQ_EN		1
+#define MIC_DET_IRQ_EN		0
+/* SUNXI_HMIC_STA */
+#define HMIC_DATA		8
+#define JACK_OUT_IRQ_STA	4
+#define JACK_IN_IRQ_STA		3
+#define MIC_DET_IRQ_STA		0
+/* SUNXI_POWER_AN_CTL */
+#define VRP_LDO_EN		24
+#define BG_BUFFER_DISABLE	15
+
+/* FIFO data registers feed the MCU DMA (dma1/mcu_dma), request 7 (BSP
+ * codec_plat node: dmas = <&dma1 7>, <&dma1 7>; maxburst 4).
+ */
+#define SUN55I_CODEC_DMA_MAXBURST	4
+
+struct sun55i_codec_jack {
+	struct snd_soc_jack	jack;
+	int			irq;
+
+	/* board parameters (BSP: jack-det-level/threshold/debouce) */
+	bool			det_level;	/* 1 = detect high */
+	unsigned int		det_threshold;
+	unsigned int		det_debounce;
+	/* BSP defaults: hook 0-0, up 2-2, down 4-5, voice 1-1 */
+	unsigned int		key_det_vol[4][2];
+
+	struct mutex		lock;
+	struct delayed_work	scan_work;
+	bool			scan_active;
+	bool			first_report;
+	int			type;
+	int			type_old;
+	unsigned int		hp_det_basedata;
+	time64_t		ts_headset_plugin;
+};
+
+struct sun55i_codec {
+	struct device		*dev;
+	struct regmap		*regmap;
+	struct clk		*clk_bus;
+	struct clk		*clk_dac;
+	struct clk		*clk_adc;
+	struct reset_control	*rst;
+	struct gpio_desc	*gpio_pa;
+
+	/* capture-side refcounting for shared MMIC bias / ADC_DIG_EN
+	 * (BSP struct sunxi_audio_status)
+	 */
+	struct mutex		acf_mutex;
+	bool			mic1;
+	bool			mic2;
+	bool			mic3;
+
+	struct sun55i_codec_jack		jack;
+	struct snd_dmaengine_dai_dma_data	playback_dma_data;
+	struct snd_dmaengine_dai_dma_data	capture_dma_data;
+};
+
+#define SUN55I_CODEC_JACK_MASK	(SND_JACK_HEADSET | SND_JACK_BTN_0 | \
+				 SND_JACK_BTN_1 | SND_JACK_BTN_2 | \
+				 SND_JACK_BTN_3)
+
+static struct sun55i_codec *snd_soc_card_to_codec(struct snd_soc_card *card)
+{
+	return snd_soc_card_get_drvdata(card);
+}
+
+static struct sun55i_codec *dai_to_codec(struct snd_soc_dai *dai)
+{
+	return snd_soc_card_to_codec(dai->component->card);
+}
+
+/*******************************************************************************
+ * DAI ops (BSP sunxi_codec_dai_ops, on the codec DAI like in the BSP)
+ ******************************************************************************/
+
+struct sun55i_codec_rate {
+	unsigned int samplerate;
+	unsigned int rate_bit;
+};
+
+/* BSP sunxi_sample_rate_conv */
+static const struct sun55i_codec_rate sun55i_codec_rates[] = {
+	{ 44100, 0 },
+	{ 48000, 0 },
+	{ 8000, 5 },
+	{ 32000, 1 },
+	{ 22050, 2 },
+	{ 24000, 2 },
+	{ 16000, 3 },
+	{ 11025, 4 },
+	{ 12000, 4 },
+	{ 192000, 6 },
+	{ 96000, 7 },
+};
+
+static int sun55i_codec_dai_startup(struct snd_pcm_substream *substream,
+				    struct snd_soc_dai *dai)
+{
+	struct sun55i_codec *scodec = dai_to_codec(dai);
+	int ret;
+
+	/* The BSP enables both module clocks (and their PLL parents,
+	 * which the CCF propagates for us) on stream startup.
+	 */
+	ret = clk_prepare_enable(scodec->clk_dac);
+	if (ret)
+		return ret;
+	ret = clk_prepare_enable(scodec->clk_adc);
+	if (ret) {
+		clk_disable_unprepare(scodec->clk_dac);
+		return ret;
+	}
+
+	return 0;
+}
+
+static void sun55i_codec_dai_shutdown(struct snd_pcm_substream *substream,
+				      struct snd_soc_dai *dai)
+{
+	struct sun55i_codec *scodec = dai_to_codec(dai);
+
+	clk_disable_unprepare(scodec->clk_adc);
+	clk_disable_unprepare(scodec->clk_dac);
+}
+
+static int sun55i_codec_dai_hw_params(struct snd_pcm_substream *substream,
+				      struct snd_pcm_hw_params *params,
+				      struct snd_soc_dai *dai)
+{
+	struct sun55i_codec *scodec = dai_to_codec(dai);
+	struct regmap *regmap = scodec->regmap;
+	bool playback = substream->stream == SNDRV_PCM_STREAM_PLAYBACK;
+	unsigned long freq;
+	int i, ret;
+
+	/*
+	 * Module clock rate: 24.576 MHz for the 48 kHz family, 22.5792 MHz
+	 * for the 44.1 kHz family (BSP machine driver, pll-fs = 1). The
+	 * BSP reparents the clock by hand (with an inconsistent branch for
+	 * the 48k family, see the port notes); in mainline the mcu-ccu
+	 * models the mux and the PLL_AUDIO1 SDM table, so a plain
+	 * clk_set_rate() yields the exact rate. Caveat: PLL_AUDIO1 is
+	 * shared with i2s2 (HDMI audio); playing different rate families
+	 * on both at once will detune whichever stream started first.
+	 */
+	switch (params_rate(params)) {
+	case 11025:
+	case 22050:
+	case 44100:
+		freq = 22579200;
+		break;
+	default:
+		freq = 24576000;
+		break;
+	}
+
+	ret = clk_set_rate(playback ? scodec->clk_dac : scodec->clk_adc, freq);
+	if (ret) {
+		dev_err(scodec->dev, "failed to set module clock to %lu: %d\n",
+			freq, ret);
+		return ret;
+	}
+
+	/* Set bits (BSP sunxi_codec_dai_hw_params) */
+	switch (params_format(params)) {
+	case SNDRV_PCM_FORMAT_S16_LE:
+		if (playback) {
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x3 << DAC_FIFO_MODE,
+					   0x3 << DAC_FIFO_MODE);
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x1 << TX_SAMPLE_BITS,
+					   0x0 << TX_SAMPLE_BITS);
+		} else {
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << RX_FIFO_MODE,
+					   0x1 << RX_FIFO_MODE);
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << RX_SAMPLE_BITS,
+					   0x0 << RX_SAMPLE_BITS);
+		}
+		break;
+	case SNDRV_PCM_FORMAT_S24_LE:
+	case SNDRV_PCM_FORMAT_S32_LE:
+		if (playback) {
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x3 << DAC_FIFO_MODE,
+					   0x0 << DAC_FIFO_MODE);
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x1 << TX_SAMPLE_BITS,
+					   0x1 << TX_SAMPLE_BITS);
+		} else {
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << RX_FIFO_MODE,
+					   0x0 << RX_FIFO_MODE);
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << RX_SAMPLE_BITS,
+					   0x1 << RX_SAMPLE_BITS);
+		}
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	/* Set rate */
+	for (i = 0; i < ARRAY_SIZE(sun55i_codec_rates); i++)
+		if (sun55i_codec_rates[i].samplerate == params_rate(params))
+			break;
+	if (i == ARRAY_SIZE(sun55i_codec_rates))
+		return -EINVAL;
+	if (playback) {
+		regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL, 0x7 << DAC_FS,
+				   sun55i_codec_rates[i].rate_bit << DAC_FS);
+	} else {
+		if (params_rate(params) > 48000)
+			return -EINVAL;
+		regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL, 0x7 << ADC_FS,
+				   sun55i_codec_rates[i].rate_bit << ADC_FS);
+	}
+
+	/* Set channels */
+	if (playback)
+		regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+				   0x1 << DAC_MONO_EN,
+				   (params_channels(params) == 1) << DAC_MONO_EN);
+
+	return 0;
+}
+
+static int sun55i_codec_dai_prepare(struct snd_pcm_substream *substream,
+				    struct snd_soc_dai *dai)
+{
+	struct sun55i_codec *scodec = dai_to_codec(dai);
+	struct regmap *regmap = scodec->regmap;
+
+	if (substream->stream == SNDRV_PCM_STREAM_PLAYBACK) {
+		regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+				   0x1 << DAC_FIFO_FLUSH, 0x1 << DAC_FIFO_FLUSH);
+		regmap_write(regmap, SUNXI_DAC_FIFO_STA,
+			     0x1 << DAC_TXE_INT | 0x1 << DAC_TXU_INT |
+			     0x1 << DAC_TXO_INT);
+		regmap_write(regmap, SUNXI_DAC_CNT, 0);
+	} else {
+		regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+				   0x1 << ADC_FIFO_FLUSH, 0x1 << ADC_FIFO_FLUSH);
+		regmap_write(regmap, SUNXI_ADC_FIFO_STA,
+			     0x1 << ADC_RXA_INT | 0x1 << ADC_RXO_INT);
+		regmap_write(regmap, SUNXI_ADC_CNT, 0);
+	}
+
+	return 0;
+}
+
+static int sun55i_codec_dai_trigger(struct snd_pcm_substream *substream,
+				    int cmd, struct snd_soc_dai *dai)
+{
+	struct sun55i_codec *scodec = dai_to_codec(dai);
+	struct regmap *regmap = scodec->regmap;
+	bool playback = substream->stream == SNDRV_PCM_STREAM_PLAYBACK;
+
+	/* Note: the BSP additionally toggles the speaker PA GPIO on
+	 * PAUSE_PUSH/RELEASE; in this port the PA is owned exclusively
+	 * by the SPK DAPM widget.
+	 */
+	switch (cmd) {
+	case SNDRV_PCM_TRIGGER_START:
+	case SNDRV_PCM_TRIGGER_RESUME:
+	case SNDRV_PCM_TRIGGER_PAUSE_RELEASE:
+		if (playback)
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x1 << DAC_DRQ_EN, 0x1 << DAC_DRQ_EN);
+		else
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << ADC_DRQ_EN, 0x1 << ADC_DRQ_EN);
+		break;
+	case SNDRV_PCM_TRIGGER_STOP:
+	case SNDRV_PCM_TRIGGER_SUSPEND:
+	case SNDRV_PCM_TRIGGER_PAUSE_PUSH:
+		if (playback)
+			regmap_update_bits(regmap, SUNXI_DAC_FIFO_CTL,
+					   0x1 << DAC_DRQ_EN, 0x0 << DAC_DRQ_EN);
+		else
+			regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+					   0x1 << ADC_DRQ_EN, 0x0 << ADC_DRQ_EN);
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
