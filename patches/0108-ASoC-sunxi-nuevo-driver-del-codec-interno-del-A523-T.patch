+/*******************************************************************************
+ * Codec init (BSP sunxi_codec_init) — hardware defaults for this board:
+ * the OPi4A DT values match the BSP driver defaults exactly
+ * (dac-vol 63 -> DVOL 0, dacl/r 160, adc1-3 160, lineout 31,
+ *  hpout 7 -> reg 0, adc gains 31), so they are hardcoded here.
+ ******************************************************************************/
+static void sun55i_codec_init(struct sun55i_codec *scodec)
+{
+	struct regmap *regmap = scodec->regmap;
+
+	regmap_update_bits(regmap, SUNXI_RAMP, 0x1 << 1, 0x1 << 1);
+
+	/* Enable DAC/ADC DAP (DRC/HPF sub-functions stay disabled) */
+	regmap_update_bits(regmap, SUNXI_DAC_DAP_CTL,
+			   0x1 << DDAP_EN, 0x1 << DDAP_EN);
+	regmap_update_bits(regmap, SUNXI_ADC_DAP_CTL,
+			   0x1 << ADAP0_EN, 0x1 << ADAP0_EN);
+	regmap_update_bits(regmap, SUNXI_ADC_DAP_CTL,
+			   0x1 << ADAP1_EN, 0x1 << ADAP1_EN);
+	/* cpvcc set 1.2V, analog power for the headphone charge pump */
+	regmap_update_bits(regmap, SUNXI_DAC_AN_REG,
+			   0x1 << CPLDO_EN, 0x1 << CPLDO_EN);
+	regmap_update_bits(regmap, SUNXI_DAC_AN_REG,
+			   0x3 << CPLDO_VOLTAGE, 0x3 << CPLDO_VOLTAGE);
+	/* HMICBIAS set to 2.55V to support MEMS and ECM mics */
+	regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+			   0x3 << HMIC_BIAS_SEL, 0x3 << HMIC_BIAS_SEL);
+	/* Open VRP to remove noise */
+	regmap_update_bits(regmap, SUNXI_POWER_AN_CTL,
+			   0x1 << VRP_LDO_EN, 0x1 << VRP_LDO_EN);
+	/* Enable ADCFDT to overcome noise at the beginning */
+	regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+			   0x1 << ADCDFEN, 0x1 << ADCDFEN);
+	regmap_update_bits(regmap, SUNXI_ADC_FIFO_CTL,
+			   0x3 << ADCFDT, 0x2 << ADCFDT);
+	/* Enable ADC1/2/3 and DACL/R volume controls */
+	regmap_update_bits(regmap, SUNXI_DAC_VOL_CTL,
+			   0x1 << DAC_VOL_SEL, 0x1 << DAC_VOL_SEL);
+	regmap_update_bits(regmap, SUNXI_ADC_DIG_CTL,
+			   0x1 << ADC1_2_VOL_EN, 0x1 << ADC1_2_VOL_EN);
+	regmap_update_bits(regmap, SUNXI_ADC_DIG_CTL,
+			   0x1 << ADC3_VOL_EN, 0x1 << ADC3_VOL_EN);
+	/*
+	 * "To solve play quietly": the BSP only pulses the bandgap buffer
+	 * on SoC versions 0/1 (read through sunxi-sid). We have no
+	 * mainline SoC-revision helper, and the pulse is harmless on
+	 * newer revisions, so do it unconditionally.
+	 */
+	regmap_update_bits(regmap, SUNXI_POWER_AN_CTL,
+			   0x1 << BG_BUFFER_DISABLE, 0x1 << BG_BUFFER_DISABLE);
+	msleep(50);
+	regmap_update_bits(regmap, SUNXI_POWER_AN_CTL,
+			   0x1 << BG_BUFFER_DISABLE, 0x0 << BG_BUFFER_DISABLE);
+
+	/* Default volume/gain values (BSP defaults == OPi4A DT values) */
+	regmap_update_bits(regmap, SUNXI_DAC_DPC, 0x3F << DVOL, 0 << DVOL);
+	regmap_update_bits(regmap, SUNXI_DAC_VOL_CTL,
+			   0xFF << DAC_VOL_L, 160 << DAC_VOL_L);
+	regmap_update_bits(regmap, SUNXI_DAC_VOL_CTL,
+			   0xFF << DAC_VOL_R, 160 << DAC_VOL_R);
+	regmap_update_bits(regmap, SUNXI_ADC_VOL_CTL1,
+			   0xFF << ADC1_VOL, 160 << ADC1_VOL);
+	regmap_update_bits(regmap, SUNXI_ADC_VOL_CTL1,
+			   0xFF << ADC2_VOL, 160 << ADC2_VOL);
+	regmap_update_bits(regmap, SUNXI_ADC_VOL_CTL1,
+			   0xFF << ADC3_VOL, 160 << ADC3_VOL);
+	regmap_update_bits(regmap, SUNXI_DAC_AN_REG,
+			   0x1F << LINEOUT_GAIN, 31 << LINEOUT_GAIN);
+	regmap_update_bits(regmap, SUNXI_DAC_AN_REG,
+			   0x7 << HEADPHONE_GAIN, 0 << HEADPHONE_GAIN);
+	regmap_update_bits(regmap, SUNXI_ADC1_AN_CTL,
+			   0x1F << ADCx_PGA_GAIN_CTL, 31 << ADCx_PGA_GAIN_CTL);
+	regmap_update_bits(regmap, SUNXI_ADC2_AN_CTL,
+			   0x1F << ADCx_PGA_GAIN_CTL, 31 << ADCx_PGA_GAIN_CTL);
+	regmap_update_bits(regmap, SUNXI_ADC3_AN_CTL,
+			   0x1F << ADCx_PGA_GAIN_CTL, 31 << ADCx_PGA_GAIN_CTL);
+}
+
