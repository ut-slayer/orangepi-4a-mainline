+/*******************************************************************************
+ * Jack detection (BSP snd_sunxi_jack_codec.c + jack callbacks of
+ * snd_sun55iw3_codec.c, JACK_DET_CODEC method). The SDBP ("slow insert")
+ * extra machinery is not used on this board (no jack-sdbp-method in DT)
+ * and was left out.
+ ******************************************************************************/
+
+enum sun55i_jack_irq_sta {
+	SUN55I_JACK_IRQ_NULL = -1,
+	SUN55I_JACK_IRQ_OUT = 0,
+	SUN55I_JACK_IRQ_IN,
+	SUN55I_JACK_IRQ_MIC,
+};
+
+/* BSP sunxi_jack_codec_init() */
+static void sun55i_codec_jack_hw_init(struct sun55i_codec *scodec)
+{
+	struct sun55i_codec_jack *jack = &scodec->jack;
+	struct regmap *regmap = scodec->regmap;
+
+	/* hp & mic det */
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL, 0xffff << 0, 0x0 << 0);
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL, 0x1f << MDATA_THRESHOLD,
+			   jack->det_threshold << MDATA_THRESHOLD);
+	regmap_update_bits(regmap, SUNXI_HMIC_STA, 0xffff << 0, 0x6000 << 0);
+	regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+			   0xff << SEL_DET_ADC_BF, 0x40 << SEL_DET_ADC_BF);
+	if (!jack->det_level) {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN,
+				   0x1 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x0 << DET_MODE);
+	} else {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN,
+				   0x0 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x1 << DET_MODE);
+	}
+
+	regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+			   0x1 << JACK_DET_EN, 0x1 << JACK_DET_EN);
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+			   0x1 << JACK_IN_IRQ_EN, 0x1 << JACK_IN_IRQ_EN);
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+			   0x1 << JACK_OUT_IRQ_EN, 0x1 << JACK_OUT_IRQ_EN);
+
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL, 0xf << HMIC_N,
+			   jack->det_debounce << HMIC_N);
+
+	regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+			   0x1 << HMIC_BIAS_EN, 0x0 << HMIC_BIAS_EN);
+	regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+			   0x1 << MIC_DET_ADC_EN, 0x0 << MIC_DET_ADC_EN);
+	regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+			   0x1 << MIC_DET_IRQ_EN, 0x0 << MIC_DET_IRQ_EN);
+}
+
+/* BSP sunxi_jack_codec_det_irq_work(), inside jack->lock */
+static void sun55i_codec_jack_handle(struct sun55i_codec *scodec,
+				     enum sun55i_jack_irq_sta sta)
+{
+	struct sun55i_codec_jack *jack = &scodec->jack;
+	struct regmap *regmap = scodec->regmap;
+	unsigned int reg_val, basedata;
+	int type = jack->type;
+
+	switch (sta) {
+	case SUN55I_JACK_IRQ_OUT:
+		regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+				   0x1 << JACK_IN_IRQ_EN, 0x1 << JACK_IN_IRQ_EN);
+		regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+				   0x1 << JACK_OUT_IRQ_EN, 0x0 << JACK_OUT_IRQ_EN);
+
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << HMIC_BIAS_EN, 0x0 << HMIC_BIAS_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << MIC_DET_ADC_EN, 0x0 << MIC_DET_ADC_EN);
+		regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+				   0x1 << MIC_DET_IRQ_EN, 0x0 << MIC_DET_IRQ_EN);
+
+		type = 0;
+		break;
+	case SUN55I_JACK_IRQ_IN:
+		regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+				   0x1 << JACK_IN_IRQ_EN, 0x0 << JACK_IN_IRQ_EN);
+		regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+				   0x1 << JACK_OUT_IRQ_EN, 0x1 << JACK_OUT_IRQ_EN);
+
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << HMIC_BIAS_EN, 0x1 << HMIC_BIAS_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << MIC_DET_ADC_EN, 0x1 << MIC_DET_ADC_EN);
+		msleep(500);
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		basedata = (reg_val >> HMIC_DATA) & 0x1f;
+
+		if (basedata > jack->det_threshold) {
+			/* headphone + mic */
+			type = SND_JACK_HEADSET;
+			jack->ts_headset_plugin = ktime_get_seconds();
+			/* slow insert: save basedata */
+			jack->hp_det_basedata = basedata;
+
+			if (basedata > 3)
+				basedata -= 3;
+
+			regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+					   0x1f << MDATA_THRESHOLD,
+					   basedata << MDATA_THRESHOLD);
+			regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+					   0x1 << MIC_DET_IRQ_EN,
+					   0x1 << MIC_DET_IRQ_EN);
+		} else {
+			regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+					   0x1 << MIC_DET_IRQ_EN,
+					   0x0 << MIC_DET_IRQ_EN);
+			regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+					   0x1 << MIC_DET_ADC_EN,
+					   0x0 << MIC_DET_ADC_EN);
+			regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+					   0x1 << HMIC_BIAS_EN,
+					   0x0 << HMIC_BIAS_EN);
+			type = SND_JACK_HEADPHONE;
+		}
+		break;
+	case SUN55I_JACK_IRQ_MIC:
+		/* slow insert: confirm basedata again */
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		reg_val = (reg_val >> HMIC_DATA) & 0x1f;
+		if (reg_val > jack->det_threshold &&
+		    abs((int)reg_val - (int)jack->hp_det_basedata) >= 3) {
+			reg_val -= 3;
+			regmap_update_bits(regmap, SUNXI_HMIC_CTL,
+					   0x1f << MDATA_THRESHOLD,
+					   reg_val << MDATA_THRESHOLD);
+		}
+
+		/* Ignore buttons right after the headset was plugged in */
+		if (ktime_get_seconds() - jack->ts_headset_plugin < 2)
+			break;
+
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		reg_val = (reg_val >> HMIC_DATA) & 0x1f;
+
+		/* BTN_0 hook, BTN_1 up, BTN_2 down, BTN_3 voice */
+		if (reg_val >= jack->key_det_vol[0][0] &&
+		    reg_val <= jack->key_det_vol[0][1])
+			type |= SND_JACK_BTN_0;
+		else if (reg_val >= jack->key_det_vol[1][0] &&
+			 reg_val <= jack->key_det_vol[1][1])
+			type |= SND_JACK_BTN_1;
+		else if (reg_val >= jack->key_det_vol[2][0] &&
+			 reg_val <= jack->key_det_vol[2][1])
+			type |= SND_JACK_BTN_2;
+		else if (reg_val >= jack->key_det_vol[3][0] &&
+			 reg_val <= jack->key_det_vol[3][1])
+			type |= SND_JACK_BTN_3;
+		else
+			dev_dbg(scodec->dev, "unsupported jack button\n");
+		break;
+	default:
+		return;
+	}
+
+	jack->type = type;
+
+	/* Reporting (BSP sunxi_jack_det_irq_work) */
+	if (jack->type == jack->type_old && !jack->first_report)
+		return;
+	jack->first_report = false;
+
+	snd_soc_jack_report(&jack->jack, jack->type, SUN55I_CODEC_JACK_MASK);
+	if (jack->type & (SND_JACK_BTN_0 | SND_JACK_BTN_1 |
+			  SND_JACK_BTN_2 | SND_JACK_BTN_3)) {
+		/* report the button release right away, like the BSP */
+		jack->type &= ~(SND_JACK_BTN_0 | SND_JACK_BTN_1 |
+				SND_JACK_BTN_2 | SND_JACK_BTN_3);
+		snd_soc_jack_report(&jack->jack, jack->type,
+				    SUN55I_CODEC_JACK_MASK);
+	}
+	jack->type_old = jack->type;
+}
+
+static irqreturn_t sun55i_codec_jack_irq(int irq, void *dev_id)
+{
+	struct sun55i_codec *scodec = dev_id;
+	struct sun55i_codec_jack *jack = &scodec->jack;
+	struct regmap *regmap = scodec->regmap;
+	enum sun55i_jack_irq_sta sta = SUN55I_JACK_IRQ_NULL;
+	unsigned int jack_state, reg_val;
+
+	/* Ack + classification (BSP sunxi_jack_codec_irq_clean) */
+	regmap_read(regmap, SUNXI_HMIC_STA, &jack_state);
+
+	if (jack_state & (1 << JACK_IN_IRQ_STA)) {
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		reg_val |= 0x1 << JACK_IN_IRQ_STA;
+		reg_val &= ~(0x1 << JACK_OUT_IRQ_STA);
+		regmap_write(regmap, SUNXI_HMIC_STA, reg_val);
+		sta = SUN55I_JACK_IRQ_IN;
+	}
+	if (jack_state & (1 << JACK_OUT_IRQ_STA)) {
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		reg_val &= ~(0x1 << JACK_IN_IRQ_STA);
+		reg_val |= 0x1 << JACK_OUT_IRQ_STA;
+		regmap_write(regmap, SUNXI_HMIC_STA, reg_val);
+		sta = SUN55I_JACK_IRQ_OUT;
+	}
+	if (jack_state & (1 << MIC_DET_IRQ_STA)) {
+		regmap_read(regmap, SUNXI_HMIC_STA, &reg_val);
+		reg_val &= ~(0x1 << JACK_IN_IRQ_STA);
+		reg_val &= ~(0x1 << JACK_OUT_IRQ_STA);
+		reg_val |= 0x1 << MIC_DET_IRQ_STA;
+		regmap_write(regmap, SUNXI_HMIC_STA, reg_val);
+		sta = SUN55I_JACK_IRQ_MIC;
+	}
+
+	/* During the boot/resume scan, interrupts are not handled */
+	if (READ_ONCE(jack->scan_active))
+		sta = SUN55I_JACK_IRQ_NULL;
+
+	if (sta == SUN55I_JACK_IRQ_NULL)
+		return IRQ_HANDLED;
+
+	mutex_lock(&jack->lock);
+	sun55i_codec_jack_handle(scodec, sta);
+	mutex_unlock(&jack->lock);
+
+	return IRQ_HANDLED;
+}
+
+/*
+ * BSP sunxi_jack_codec_det_scan_work(): briefly invert the detection
+ * mode so the hardware retriggers the in/out interrupt, which then
+ * reports the real jack state. Used once at boot (2s after probe).
+ */
+static void sun55i_codec_jack_scan_work(struct work_struct *work)
+{
+	struct sun55i_codec_jack *jack =
+		container_of(work, struct sun55i_codec_jack, scan_work.work);
+	struct sun55i_codec *scodec =
+		container_of(jack, struct sun55i_codec, jack);
+	struct regmap *regmap = scodec->regmap;
+
+	mutex_lock(&jack->lock);
+	WRITE_ONCE(jack->scan_active, true);
+	if (!jack->det_level) {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN, 0x0 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x1 << DET_MODE);
+	} else {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN, 0x1 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x0 << DET_MODE);
+	}
+
+	/* must ensure that the interrupt triggers (BSP: 500ms) */
+	msleep(500);
+
+	WRITE_ONCE(jack->scan_active, false);
+	if (!jack->det_level) {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN, 0x1 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x0 << DET_MODE);
+	} else {
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << AUTO_PULL_LOW_EN, 0x0 << AUTO_PULL_LOW_EN);
+		regmap_update_bits(regmap, SUNXI_MICBIAS_AN_CTL,
+				   0x1 << DET_MODE, 0x1 << DET_MODE);
+	}
+	mutex_unlock(&jack->lock);
+}
+
+/*******************************************************************************
+ * Card (BSP codec_mach translated: pin switches + jack)
+ ******************************************************************************/
+
+static const struct snd_kcontrol_new sun55i_codec_card_controls[] = {
+	SOC_DAPM_PIN_SWITCH("MIC1"),
+	SOC_DAPM_PIN_SWITCH("MIC2"),
+	SOC_DAPM_PIN_SWITCH("MIC3"),
+	SOC_DAPM_PIN_SWITCH("LINEOUTL"),
+	SOC_DAPM_PIN_SWITCH("LINEOUTR"),
+	SOC_DAPM_PIN_SWITCH("HPOUT"),
+	SOC_DAPM_PIN_SWITCH("SPK"),
+};
+
+static int sun55i_codec_machine_init(struct snd_soc_pcm_runtime *rtd)
+{
+	struct snd_soc_card *card = rtd->card;
+	struct sun55i_codec *scodec = snd_soc_card_get_drvdata(card);
+	struct sun55i_codec_jack *jack = &scodec->jack;
+	int ret;
+
+	if (jack->irq <= 0)
+		return 0;
+
+	ret = snd_soc_card_jack_new(card, "Headphone",
+				    SUN55I_CODEC_JACK_MASK, &jack->jack);
+	if (ret) {
+		dev_err(card->dev, "jack creation failed: %d\n", ret);
+		return ret;
+	}
+
+	/* BSP key mapping */
+	snd_jack_set_key(jack->jack.jack, SND_JACK_BTN_0, KEY_MEDIA);
+	snd_jack_set_key(jack->jack.jack, SND_JACK_BTN_1, KEY_VOLUMEUP);
+	snd_jack_set_key(jack->jack.jack, SND_JACK_BTN_2, KEY_VOLUMEDOWN);
+	snd_jack_set_key(jack->jack.jack, SND_JACK_BTN_3, KEY_VOICECOMMAND);
+
+	sun55i_codec_jack_hw_init(scodec);
+
+	ret = devm_request_threaded_irq(scodec->dev, jack->irq, NULL,
+					sun55i_codec_jack_irq, IRQF_ONESHOT,
+					"sun55i-codec-jack", scodec);
+	if (ret) {
+		dev_err(card->dev, "jack irq request failed: %d\n", ret);
+		return ret;
+	}
+
+	/* BSP: recheck 2s after boot to detect an already-inserted jack */
+	schedule_delayed_work(&jack->scan_work, msecs_to_jiffies(2000));
+
+	return 0;
+}
+
+static struct snd_soc_card *sun55i_codec_create_card(struct device *dev)
+{
+	struct snd_soc_card *card;
+	struct snd_soc_dai_link *link;
+	struct snd_soc_dai_link_component *dlc;
+
+	card = devm_kzalloc(dev, sizeof(*card), GFP_KERNEL);
+	link = devm_kzalloc(dev, sizeof(*link), GFP_KERNEL);
+	dlc = devm_kzalloc(dev, 3 * sizeof(*dlc), GFP_KERNEL);
+	if (!card || !link || !dlc)
+		return ERR_PTR(-ENOMEM);
+
+	link->cpus		= &dlc[0];
+	link->codecs		= &dlc[1];
+	link->platforms		= &dlc[2];
+	link->num_cpus		= 1;
+	link->num_codecs	= 1;
+	link->num_platforms	= 1;
+
+	link->name		= "cdc";
+	link->stream_name	= "CDC PCM";
+	link->codecs->dai_name	= "Codec";
+	link->cpus->dai_name	= dev_name(dev);
+	link->codecs->name	= dev_name(dev);
+	link->platforms->name	= dev_name(dev);
+	link->init		= sun55i_codec_machine_init;
+
+	card->dai_link		= link;
+	card->num_links		= 1;
+	card->dev		= dev;
+	card->owner		= THIS_MODULE;
+	card->name		= "audiocodec";
+	card->controls		= sun55i_codec_card_controls;
+	card->num_controls	= ARRAY_SIZE(sun55i_codec_card_controls);
+
+	return card;
+}
