From 0d88879eb474578f4fd3fb7fb9801a3ac0fdeeec Mon Sep 17 00:00:00 2001
From: Jernej Skrabec <jernej.skrabec@gmail.com>
Date: Wed, 8 Jul 2026 18:08:05 +0200
Subject: [PATCH 024/129] drm/sun4i: compatible display-engine del H616
 (minimyth2 2407)

Origen: serie display A523 de Justin Suess empaquetada en minimyth2
(warpme), backport a 6.18.36.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>

Parche original de la serie A523/H616 recopilada en minimyth2
(autoria git = autor original). Port y adaptacion a 6.18/T527:
Juan Manuel Lopez Carrillo (AurealNix) <juanmanuellopezcarrillo@gmail.com>.
---
 drivers/gpu/drm/sun4i/sun4i_drv.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/gpu/drm/sun4i/sun4i_drv.c b/drivers/gpu/drm/sun4i/sun4i_drv.c
index c11dfb273..6986b3292 100644
--- a/drivers/gpu/drm/sun4i/sun4i_drv.c
+++ b/drivers/gpu/drm/sun4i/sun4i_drv.c
@@ -436,6 +436,7 @@ static const struct of_device_id sun4i_drv_of_table[] = {
 	{ .compatible = "allwinner,sun20i-d1-display-engine" },
 	{ .compatible = "allwinner,sun50i-a64-display-engine" },
 	{ .compatible = "allwinner,sun50i-h6-display-engine" },
+	{ .compatible = "allwinner,sun50i-h616-display-engine" },
 	{ }
 };
 MODULE_DEVICE_TABLE(of, sun4i_drv_of_table);
