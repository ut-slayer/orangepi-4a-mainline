From 7aad6b373488785e419dc1d51c0ef0a2589a7ab3 Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Wed, 8 Jul 2026 18:22:09 +0200
Subject: [PATCH 042/130] dts: opi4a: PD_VO0 en tcon-top/tcon-tv y CLK_DE a
 600MHz como el BSP

Hallazgos de la auditoria vs BSP: el dtsi de la serie no reclama la isla
VO0 desde tcon-top/tcon-tv (solo desde hdmi) y no fija rate/padre de
CLK_DE (el BSP usa PLL_VIDEO3_4X @600MHz via assigned-clocks).

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .../dts/allwinner/sun55i-t527-orangepi-4a.dts | 24 +++++++++++++++++++
 1 file changed, 24 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
index 98aca4c7f..8025a1b72 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
@@ -620,3 +620,27 @@ hdmi_out_con: endpoint {
 		remote-endpoint = <&hdmi_con_in>;
 	};
 };
+
+/*
+ * Adaptaciones de la auditoria contra el BSP 5.15 (fuente de verdad):
+ * - El BSP cuelga vo0/tcon de la isla VO0 (A523_PCK_VO0); el dtsi del
+ *   parche solo la reclama desde el nodo hdmi. Reclamarla tambien en
+ *   tcon-top y tcon-tv evita tocar registros con la isla apagada y
+ *   protege del barrido de sync_state (ya mordio con simpledrm).
+ * - El BSP fija CLK_DE a 600 MHz colgado de PLL_VIDEO3_4X
+ *   (assigned-clocks del nodo de@5000000 del BSP); el dtsi del parche
+ *   no fijaba rate y el mux podia quedarse en el padre de reset.
+ */
+&tcon_top {
+	power-domains = <&pck600 PD_VO0>;
+};
+
+&tcon_tv0 {
+	power-domains = <&pck600 PD_VO0>;
+};
+
+&display_clocks {
+	assigned-clocks = <&ccu CLK_DE>;
+	assigned-clock-parents = <&ccu CLK_PLL_VIDEO3_4X>;
+	assigned-clock-rates = <600000000>;
+};
