From 779042fcbbdf2ff88fea3568a10a418566835aea Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Sat, 18 Jul 2026 06:01:18 +0200
Subject: [PATCH 122/130] arm64: dts: sun55i-t527-orangepi-4a: PCIe con 1 lane
 (dato del BSP)

El parche de armbian ponia num-lanes = <2>, pero la fuente de verdad
(BSP 5.15, sun55iw3p1.dtsi linea 5066: num-lanes = <1>, sin override en
sun55i-t527-orangepi-4a.dts) dice que el T527 saca UNA lane al M.2; la
lane del combophy Inno es unica y muxada con USB3. Con 2 lanes el core
DWC negociaria un ancho inexistente. Se normaliza tambien la
indentacion del bloque (espacios mezclados del parche original) y se
comentan los GPIOs (PH11 PERST#, PH12 WAKE#).

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .../boot/dts/allwinner/sun55i-t527-orangepi-4a.dts     | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
index e5a0c63f5..0d81bd040 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
@@ -726,15 +726,15 @@ bluetooth {
 };
 
 &combophy {
-       resets = <&ccu RST_BUS_PCIE_USB3>;
-    	phy_use_sel = <0>;
+	resets = <&ccu RST_BUS_PCIE_USB3>;
+	phy_use_sel = <0>; /* 0:PCIE; 1:USB3 */
 	status = "okay";
 };
 
 &pcie {
-	reset-gpios = <&pio 7 11 GPIO_ACTIVE_HIGH>;
-	wake-gpios = <&pio 7 12 GPIO_ACTIVE_HIGH>;
-	num-lanes = <2>;
+	reset-gpios = <&pio 7 11 GPIO_ACTIVE_HIGH>; /* PH11, PERST# */
+	wake-gpios = <&pio 7 12 GPIO_ACTIVE_HIGH>;  /* PH12, WAKE# */
+	num-lanes = <1>;
 	clk-freq-100M;
 	pcie3v3-supply = <&reg_pcie_vcc3v3>;
 	status = "okay";
