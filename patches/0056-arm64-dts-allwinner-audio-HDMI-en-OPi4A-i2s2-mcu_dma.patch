From 4f5c49460775fe286a2f1734aa86d858de95551b Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Fri, 10 Jul 2026 02:16:35 +0200
Subject: [PATCH 056/131] arm64: dts: allwinner: audio HDMI en OPi4A (i2s2 +
 mcu_dma + simple-card)

Receta del BSP 5.15: I2S2@0x7114000 -> entrada I2S del DW-HDMI (cableado
interno, dma1 req 5, tarjeta sndhdmi, 2x32bit CPU master). Nodos i2s2 y
mcu_dma tomados de upstream master (serie I2S A523 de Chen-Yu Tsai);
dma-channels=8 segun el dts del BSP (upstream dice 16). #sound-dai-cells
en el nodo hdmi + simple-audio-card patron rk3328 (mclk-fs 128). Cero
cambios de codigo: sun4i-i2s (fallback r329), sun6i-dma (fallback a100),
dw-hdmi-i2s-audio y hdmi-codec ya estaban compilados como modulos.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .../arm64/boot/dts/allwinner/sun55i-a523.dtsi | 28 +++++++++++++++
 .../dts/allwinner/sun55i-t527-orangepi-4a.dts | 34 +++++++++++++++++++
 2 files changed, 62 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index ede603c8e..25cddf094 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -299,6 +299,7 @@ hdmi: hdmi@5520000 {
 			power-domains = <&pck600 PD_VO0>;
 			phys = <&hdmi_phy>;
 			phy-names = "phy";
+			#sound-dai-cells = <0>;
 			status = "disabled";
 
 			ports {
@@ -1000,6 +1001,33 @@ mcu_ccu: clock-controller@7102000 {
 			#reset-cells = <1>;
 		};
 
+		i2s2: i2s@7114000 {
+			compatible = "allwinner,sun55i-a523-i2s",
+				     "allwinner,sun50i-r329-i2s";
+			reg = <0x07114000 0x1000>;
+			interrupts = <GIC_SPI 194 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&mcu_ccu CLK_BUS_MCU_I2S2>, <&mcu_ccu CLK_MCU_I2S2>;
+			clock-names = "apb", "mod";
+			resets = <&mcu_ccu RST_BUS_MCU_I2S2>;
+			dmas = <&mcu_dma 5>, <&mcu_dma 5>;
+			dma-names = "rx", "tx";
+			#sound-dai-cells = <0>;
+			status = "disabled";
+		};
+
+		mcu_dma: dma-controller@7121000 {
+			compatible = "allwinner,sun55i-a523-mcu-dma",
+				     "allwinner,sun50i-a100-dma";
+			reg = <0x07121000 0x1000>;
+			interrupts = <GIC_SPI 197 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&mcu_ccu CLK_BUS_MCU_DMA>, <&mcu_ccu CLK_MCU_MBUS_DMA>;
+			clock-names = "bus", "mbus";
+			dma-channels = <8>;
+			dma-requests = <15>;
+			resets = <&mcu_ccu RST_BUS_MCU_DMA>;
+			#dma-cells = <1>;
+		};
+
 		npu: npu@7122000 {
 			compatible = "vivante,gc";
 			reg = <0x07122000 0x1000>;
diff --git a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
index 05e49c4c0..dc70a09bd 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
@@ -675,3 +675,37 @@ &display_clocks {
  * (invalidacion por rango + prefetch vendor) y guardas de diagnostico
  * contra el DTE corrupto del Oops de boot 1.
  */
+
+/*
+ * AUDIO HDMI (receta del BSP 5.15, fuente de verdad): el BSP saca el audio
+ * HDMI por I2S2 (i2s2_plat@7114000, dma1 req 5, tarjeta "sndhdmi",
+ * formato i2s, 2 slots de 32 bits, CPU master, sin MCLK) hacia la entrada
+ * I2S del DW-HDMI (cableado interno del SoC, sin pinctrl). En mainline el
+ * equivalente es sun4i-i2s (fallback r329, mismo layout de registros) +
+ * dw-hdmi-i2s-audio (el core ya registra el codec: CONFIG3 trae GPAUD,
+ * verificado en vivo) + simple-audio-card, patron rk3328. Los nodos i2s2 y
+ * mcu_dma son los de upstream master (serie I2S A523 de Chen-Yu Tsai),
+ * salvo dma-channels=8 que es lo que dice el dts del BSP (upstream pone 16).
+ * mclk-fs=128: el DW-HDMI no consume MCLK pero sun4i-i2s deriva de el los
+ * divisores de BCLK.
+ */
+&i2s2 {
+	status = "okay";
+};
+
+/ {
+	hdmi_sound: hdmi-sound {
+		compatible = "simple-audio-card";
+		simple-audio-card,name = "sndhdmi";
+		simple-audio-card,format = "i2s";
+		simple-audio-card,mclk-fs = <128>;
+
+		simple-audio-card,cpu {
+			sound-dai = <&i2s2>;
+		};
+
+		simple-audio-card,codec {
+			sound-dai = <&hdmi>;
+		};
+	};
+};
