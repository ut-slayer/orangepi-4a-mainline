Subject: [PATCH 089/106] =?UTF-8?q?arm64:=20dts:=20sun55i-a523:=20a=C3=B1a?=
 =?UTF-8?q?dir=20el=20THS=20de=20DDR?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Nodo thermal-sensor@200a000 (1 sensor DDR, reloj CLK_GPADC0, reset
compartido RST_BUS_THS) y la zona ddr-thermal (solo monitorización, sin
trips, como el BSP).

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
index 20c017d37..c1df428e2 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
+++ b/arch/arm64/boot/dts/allwinner/sun55i-a523.dtsi
@@ -203,6 +203,12 @@ npu-thermal {
 			polling-delay = <1000>;
 			thermal-sensors = <&ths 3>;
 		};
+
+		ddr-thermal {
+			polling-delay-passive = <0>;
+			polling-delay = <1000>;
+			thermal-sensors = <&ths_ddr 0>;
+		};
 	};
 
 	soc {
@@ -538,6 +544,17 @@ ths: thermal-sensor@2009400 {
 			#thermal-sensor-cells = <1>;
 		};
 
+		ths_ddr: thermal-sensor@200a000 {
+			compatible = "allwinner,sun55i-a523-ths-ddr";
+			reg = <0x0200a000 0x400>;
+			clocks = <&ccu CLK_BUS_THS>, <&ccu CLK_GPADC0>;
+			clock-names = "bus", "mod";
+			resets = <&ccu RST_BUS_THS>;
+			nvmem-cells = <&ths_calibration>;
+			nvmem-cell-names = "calibration";
+			#thermal-sensor-cells = <1>;
+		};
+
 		iommu: iommu@2010000 {
 				compatible = "allwinner,sun55i-a523-iommu",
 				"allwinner,sun50i-h616-iommu";
-- 
