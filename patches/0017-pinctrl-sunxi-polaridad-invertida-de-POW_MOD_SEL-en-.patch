From 28294563fd449e9d20134c1384d3553d9d91902c Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Wed, 8 Jul 2026 10:53:54 +0200
Subject: [PATCH 017/130] pinctrl: sunxi: polaridad invertida de POW_MOD_SEL en
 A523/T527 (io_bias_reverse)

El fixup del probe dejaba los bancos bien, pero al aplicar pinconf de
pines con vcc-pX-supply declarado, sunxi_pinctrl_set_io_bias_cfg
volvia a romperlos: escribe POW_MOD_SEL con la convencion de H616
(bit=1 -> modo 1.8V) y en el A523/T527 el bit esta INVERTIDO
(bit=1 -> modo 3.3V, 'power_mode_reverse' del BSP). Con
vcc-pj-supply=cldo1 (1.8V) mainline ponia bit9=1 = modo 3.3V y el
RX del GMAC1 volvia a morir tras el arranque (observado en frio:
0x11ab del fixup -> 0x12c5 reescrito; limpiar bit9 en vivo -> ping
0% loss).

Nuevo flag io_bias_reverse en sunxi_pinctrl_desc, activado en los
descs de a523 y a523-r. Candidato a upstream: el driver mainline
esta mal para todos los A523.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 drivers/pinctrl/sunxi/pinctrl-sun55i-a523-r.c | 1 +
 drivers/pinctrl/sunxi/pinctrl-sun55i-a523.c   | 1 +
 drivers/pinctrl/sunxi/pinctrl-sunxi.c         | 6 ++++++
 drivers/pinctrl/sunxi/pinctrl-sunxi.h         | 3 +++
 4 files changed, 11 insertions(+)

diff --git a/drivers/pinctrl/sunxi/pinctrl-sun55i-a523-r.c b/drivers/pinctrl/sunxi/pinctrl-sun55i-a523-r.c
index 69cd2b4eb..d16149475 100644
--- a/drivers/pinctrl/sunxi/pinctrl-sun55i-a523-r.c
+++ b/drivers/pinctrl/sunxi/pinctrl-sun55i-a523-r.c
@@ -28,6 +28,7 @@ static struct sunxi_pinctrl_desc a523_r_pinctrl_data = {
 	.irq_bank_map = a523_r_irq_bank_map,
 	.irq_read_needs_mux = true,
 	.io_bias_cfg_variant = BIAS_VOLTAGE_PIO_POW_MODE_SEL,
+	.io_bias_reverse = true,
 	.pin_base = PL_BASE,
 };
 
diff --git a/drivers/pinctrl/sunxi/pinctrl-sun55i-a523.c b/drivers/pinctrl/sunxi/pinctrl-sun55i-a523.c
index 537043dba..5d8ca2915 100644
--- a/drivers/pinctrl/sunxi/pinctrl-sun55i-a523.c
+++ b/drivers/pinctrl/sunxi/pinctrl-sun55i-a523.c
@@ -95,6 +95,7 @@ static struct sunxi_pinctrl_desc a523_pinctrl_data = {
 	.irq_bank_map = a523_irq_bank_map,
 	.irq_read_needs_mux = true,
 	.io_bias_cfg_variant = BIAS_VOLTAGE_PIO_POW_MODE_SEL,
+	.io_bias_reverse = true,
 };
 
 static int a523_pinctrl_probe(struct platform_device *pdev)
diff --git a/drivers/pinctrl/sunxi/pinctrl-sunxi.c b/drivers/pinctrl/sunxi/pinctrl-sunxi.c
index 0fb057a07..4ad951874 100644
--- a/drivers/pinctrl/sunxi/pinctrl-sunxi.c
+++ b/drivers/pinctrl/sunxi/pinctrl-sunxi.c
@@ -752,6 +752,12 @@ static int sunxi_pinctrl_set_io_bias_cfg(struct sunxi_pinctrl *pctl,
 	case BIAS_VOLTAGE_PIO_POW_MODE_SEL:
 		val = uV <= 1800000 ? 1 : 0;
 
+		/* En A523/T527 el significado del bit esta invertido
+		 * (1 = modo 3.3V); con la convencion de H616 el banco
+		 * queda con umbrales erroneos y las entradas mudas. */
+		if (pctl->desc->io_bias_reverse)
+			val = !val;
+
 		raw_spin_lock_irqsave(&pctl->lock, flags);
 		reg = readl(pctl->membase + pctl->pow_mod_sel_offset);
 		reg &= ~(1 << bank);
diff --git a/drivers/pinctrl/sunxi/pinctrl-sunxi.h b/drivers/pinctrl/sunxi/pinctrl-sunxi.h
index ad26e4de1..4c742a169 100644
--- a/drivers/pinctrl/sunxi/pinctrl-sunxi.h
+++ b/drivers/pinctrl/sunxi/pinctrl-sunxi.h
@@ -141,6 +141,9 @@ struct sunxi_pinctrl_desc {
 	bool				irq_read_needs_mux;
 	bool				disable_strict_mode;
 	enum sunxi_desc_bias_voltage	io_bias_cfg_variant;
+	/* A523/T527: POW_MOD_SEL con polaridad invertida (bit=1 -> modo
+	 * 3.3V, bit=0 -> 1.8V), al reves que H616 y anteriores. */
+	bool				io_bias_reverse;
 };
 
 struct sunxi_pinctrl_function {
