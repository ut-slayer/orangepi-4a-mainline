 	 * Write the head dirty flags the hardware consumes NOW, from the
@@ -1574,21 +1642,14 @@ static void sun55i_de_do_arm(struct sun55i_de *de)
 	sun55i_de_age_fb_holds(de);
 
 	/*
-	 * Retry self-sufficiency: the pending retries (arms_left /
-	 * full_arms_left) and the fb-hold aging above are normally driven by
-	 * the NEXT vblank IRQ - but DRM may disable it at any time once the
-	 * flip event is delivered (drm.vblankoffdelay), freezing the retries
-	 * (hw/shadow divergence) and pinning the held fbs until the next
-	 * commit. Schedule the hrtimer one full frame ahead (same beam
-	 * position = still blanking) as a fallback kick that needs no vblank;
-	 * if the vblank IRQ does come first, both paths take arm_lock and
-	 * check arm_pending, so the work is done once either way.
+	 * La programacion del retry (arms_left / full_arms_left pendientes) es
+	 * responsabilidad del llamante: tanto el vblank IRQ como el callback
+	 * del timer re-anclan cada salto a la linea REAL del TCON via
+	 * sun55i_de_lines_to_target(), nunca a un periodo fijo en lazo
+	 * abierto (la deriva acumulada de aquel esquema sacaba los arms del
+	 * blanking: el wedge 2026-07-18).
 	 */
-	if (de->arm_pending && de->ns_per_line && de->line_total &&
-	    !hrtimer_active(&de->arm_timer))
-		hrtimer_start(&de->arm_timer,
-			      ns_to_ktime((u64)de->line_total * de->ns_per_line),
-			      HRTIMER_MODE_REL);
+	return 0;
 }
 
 /*
@@ -1682,35 +1743,58 @@ static u32 sun55i_de_arm_target(struct sun55i_de *de)
 }
 
 /*
- * hrtimer callback: the beam was in active video (or past the target) when the
- * vblank IRQ fired, so the arm was scheduled to land here, at the computed time
- * the beam next re-enters the leading blanking. Arm now. Runs in hardirq
- * context; RCQ_CTL is non-sleeping MMIO. Replaces the vendor's usleep-to-
- * blanking from a system_wq work item (disp_mgr_protect_reg_for_rcq) with a
- * precise absolute-time fire, which is deterministic regardless of the vblank
- * IRQ's servicing latency.
+ * Lineas de contador hasta el proximo punto seguro de arm (el target del
+ * vendor, dentro del blanking inicial), medidas sobre la linea REAL del TCON.
+ * Todo salto del hrtimer se calcula con esto: re-anclado al haz en cada hop,
+ * nunca un periodo fijo en lazo abierto (la deriva acumulada sacaba los arms
+ * del blanking, ver el beam-gate de do_arm). @next_frame salta el target del
+ * frame en curso aunque quede por delante (retries: max un arm por frame).
+ */
+static u32 sun55i_de_lines_to_target(struct sun55i_de *de, bool next_frame)
+{
+	u32 target = sun55i_de_arm_target(de);
+	u32 cur, lines;
+
+	if (!tcon_curline_io || !de->line_total)
+		return de->line_total ? de->line_total : 1;
+
+	cur = readl(tcon_curline_io) & 0xfff;
+	if (!next_frame && cur < target)
+		return target - cur;
+
+	lines = (cur < de->line_total ? de->line_total - cur : 0) + target;
+	return lines ? lines : 1;
+}
+
+/*
+ * hrtimer callback: respaldo del arm inicial (commit), arm diferido (el vblank
+ * IRQ pillo el haz fuera de la ventana) o retry (arms_left/full_arms_left).
+ * Runs in hardirq context; la copia AHB es MMIO no bloqueante. Cada salto se
+ * re-ancla a la linea real del TCON (el beam-gate de do_arm devuelve la espera
+ * exacta; para un retry se apunta al target del frame siguiente) - nunca un
+ * periodo fijo en lazo abierto (fix wedge 2026-07-18).
  */
 static enum hrtimer_restart sun55i_de_arm_timer(struct hrtimer *t)
 {
 	struct sun55i_de *de = container_of(t, struct sun55i_de, arm_timer);
 	enum hrtimer_restart ret = HRTIMER_NORESTART;
 	unsigned long flags;
+	u32 wait = 0;
 
 	spin_lock_irqsave(&de->arm_lock, flags);
 	if (de->arm_pending)
-		sun55i_de_do_arm(de);
+		wait = sun55i_de_do_arm(de);
 
 	/*
-	 * Keep the retry chain alive from the timer itself: inside the
-	 * callback hrtimer_active() is true, so the fallback re-arm in
-	 * do_arm() cannot fire here - forward one full frame (same beam
-	 * position = still blanking) and restart. quiesce() clears
+	 * Keep the chain alive from the timer itself. quiesce() clears
 	 * arm_pending under the lock first, so its hrtimer_cancel() never
-	 * races a restart.
+	 * races a restart. wait != 0 = do_arm defirio el arm (beam-gate);
+	 * si no, un retry pendiente se apunta al target del frame siguiente.
 	 */
 	if (de->arm_pending && de->ns_per_line && de->line_total) {
-		hrtimer_forward_now(t, ns_to_ktime((u64)de->line_total *
-						   de->ns_per_line));
+		if (!wait)
+			wait = sun55i_de_lines_to_target(de, true);
+		hrtimer_forward_now(t, ns_to_ktime((u64)wait * de->ns_per_line));
 		ret = HRTIMER_RESTART;
 	}
 	spin_unlock_irqrestore(&de->arm_lock, flags);
@@ -1746,11 +1830,24 @@ void sun55i_de_vblank_quirk(struct sun8i_mixer *mixer, unsigned int cur_line)
 
 	spin_lock_irqsave(&de->arm_lock, flags);
 
-	/* nothing staged, or a timed arm is already pending for this commit */
-	if (!de->arm_pending || hrtimer_active(&de->arm_timer))
+	if (!de->arm_pending)
+		goto out;
+
+	/*
+	 * Puede haber un timer en vuelo (respaldo del commit, retry o arm
+	 * diferido del frame anterior). El arm del IRQ esta anclado al vblank
+	 * REAL, asi que es el preferente: reclamar el timer - salvo que su
+	 * callback ya este corriendo en otra CPU (esta girando en arm_lock y
+	 * hara el trabajo el mismo en cuanto soltemos el lock). El esquema
+	 * anterior (saltarse el arm con el timer activo) convertia al timer
+	 * en el UNICO camino de arm bajo commits sostenidos, y su deriva en
+	 * lazo abierto sacaba los applies del blanking (wedge 2026-07-18).
+	 */
+	if (hrtimer_try_to_cancel(&de->arm_timer) < 0)
 		goto out;
 
 	target = sun55i_de_arm_target(de);
+	lines = 0;
 
 	if (!de->ns_per_line) {
 		/* no timing info (mode_set not run yet): arm now */
@@ -1758,7 +1855,10 @@ void sun55i_de_vblank_quirk(struct sun8i_mixer *mixer, unsigned int cur_line)
 	} else if (cur_line <= target && !arm_at_target) {
 		/* already before the target and not asked to wait: arm now */
 		dbg_arm_now++;
-		sun55i_de_do_arm(de);
+		lines = sun55i_de_do_arm(de);
+		/* retries pendientes: max un arm por frame, al proximo target */
+		if (!lines && de->arm_pending)
+			lines = sun55i_de_lines_to_target(de, true);
 	} else {
 		/*
 		 * Sleep to the target line and arm there. If the target is
@@ -1777,10 +1877,12 @@ void sun55i_de_vblank_quirk(struct sun8i_mixer *mixer, unsigned int cur_line)
 		}
 		de->arm_deferred++;
 		dbg_arm_late++;
+	}
+
+	if (lines && de->ns_per_line)
 		hrtimer_start(&de->arm_timer,
 			      ns_to_ktime((u64)lines * de->ns_per_line),
 			      HRTIMER_MODE_REL);
-	}
 
 out:
 	spin_unlock_irqrestore(&de->arm_lock, flags);
