- * blocks ~immediately. Caller must hold arm_lock and have confirmed the beam is
- * in a blanking window. Mirrors de_top_set_rcq_update(disp, 1).
+ * Issue the RCQ load (RCQ_CTL = 1) / the AHB copy. Caller must hold arm_lock.
+ * The beam position is (re)checked HERE, covering every caller: returns 0 when
+ * the arm was issued, or the number of counter lines to wait before retrying
+ * when the beam was outside the safe window (the caller schedules the hrtimer;
+ * the timer callback uses hrtimer_forward). Mirrors de_top_set_rcq_update().
  */
 /*
  * TEMP diagnostico C4 pantalla-negra: volcar cabecera RCQ + sombra de los
@@ -1434,10 +1474,37 @@ static void sun55i_de_dump_blocks(struct sun55i_de *de, const char *tag,
 	}
 }
 
-static void sun55i_de_do_arm(struct sun55i_de *de)
+static u32 sun55i_de_do_arm(struct sun55i_de *de)
 {
 	u32 status = 0;
 
+	/*
+	 * Beam-gate de TODO arm (fix wedge 2026-07-18). Antes solo el arm del
+	 * vblank IRQ comprobaba el haz; los del hrtimer (retries) corrian en
+	 * lazo abierto a line_total*ns_per_line por salto (ns truncados,
+	 * CLOCK_MONOTONIC vs el dotclock real del PLL) y, como vblank_quirk
+	 * se saltaba el arm con el timer activo, con commits sostenidos a
+	 * 60 fps el timer era el UNICO camino de arm: el punto derivaba por
+	 * todo el frame y los bloques AHB se aplicaban en pleno scanout /
+	 * prefetch del DE. Un toggle OVL<->AFBD (transicion direct-scanout de
+	 * wlroots) aplicado a mitad de fetch es el principal sospechoso de
+	 * colgar el latch de config del canal (frame clavado 2026-07-18).
+	 * Releer aqui la linea real cubre a todos los llamantes; fuera de la
+	 * ventana segura [0, line_active) se difiere al proximo target,
+	 * acotado a 3 saltos (un contador ilegible/roto solo puede retrasar
