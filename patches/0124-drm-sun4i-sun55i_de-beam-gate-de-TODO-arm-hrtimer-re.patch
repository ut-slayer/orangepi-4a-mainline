-			  (mode->crtc_vtotal - mode->crtc_vsync_start);
+	dbg_line_active = de->line_active;
 	dbg_line_total  = de->line_total;
 	dbg_ns_per_line = de->ns_per_line;
 	dbg_arm_target  = sun55i_de_arm_target(de);
@@ -781,6 +791,7 @@ void sun55i_de_mode_set(struct sun8i_mixer *mixer,
 	dbg_arm_line_max  = -1;
 	dbg_arm_now = dbg_arm_late = dbg_commits = dbg_coalesced = 0;
 	dbg_arm_busy = 0;
+	dbg_arm_gated = 0;
 
 	/* --- datapath: staged into the RCQ shadow --- */
 
@@ -846,6 +857,8 @@ void sun55i_de_enable(struct sun8i_mixer *mixer,
 	de->quiesced = false;	/* commits may hold fbs and arm again */
 	de->rcq_kicked = false;	/* the reset pulse below clears the RCQ state */
 	de->rcq_skips = 0;
+	de->arm_gate_skips = 0;
+	de->stall_commits = 0;
 	spin_unlock_irqrestore(&de->arm_lock, flags);
 
 	/*
@@ -1376,6 +1389,31 @@ void sun55i_de_commit(struct sun8i_mixer *mixer)
 	de->commit_seq++;
 	dbg_commits++;
 	de->arm_pending = true;
+
+	/*
+	 * Cadena de arms muerta = frame clavado sin UN SOLO error en dmesg
+	 * (el compositor sigue commiteando, los holds no envejecen y el DE
+	 * escanea el fb viejo para siempre). Delatarla: ~2 s de commits sin
+	 * que ningun arm los aplique.
+	 */
+	if (++de->stall_commits == 120)
+		pr_warn("sun55i_de: 120 commits sin arm (arm_seq=%u); cadena de arms atascada\n",
+			de->arm_seq);
+
+	/*
+	 * Respaldo del arm inicial (fix wedge 2026-07-18): el primer arm de
+	 * un commit dependia al 100% del vblank IRQ del TCON (el hrtimer solo
+	 * se armaba desde do_arm para los retries); si ese IRQ muere,
+	 * arm_pending queda pendiente para siempre. Programado al proximo
+	 * punto seguro; si el vblank IRQ llega antes lo reclama
+	 * (hrtimer_try_to_cancel en vblank_quirk) y arma el, asi que en
+	 * operacion normal este timer no llega a disparar.
+	 */
+	if (!hrtimer_active(&de->arm_timer) && de->ns_per_line && de->line_total)
+		hrtimer_start(&de->arm_timer,
+			      ns_to_ktime((u64)sun55i_de_lines_to_target(de, false) *
+					  de->ns_per_line),
+			      HRTIMER_MODE_REL);
 }
 
 /*
@@ -1397,9 +1435,11 @@ void sun55i_de_stage_unlock(struct sun8i_mixer *mixer, unsigned long *flags)
 }
 
