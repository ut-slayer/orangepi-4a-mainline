+	 */
+	if (tcon_curline_io && de->line_active && de->ns_per_line) {
+		u32 cur = readl(tcon_curline_io) & 0xfff;
+
+		if (cur >= de->line_active && de->arm_gate_skips < 3) {
+			de->arm_gate_skips++;
+			dbg_arm_gated++;
+			return sun55i_de_lines_to_target(de, false);
+		}
+	}
+	de->arm_gate_skips = 0;
+
 	regmap_read(de->mixer->top_regs, SUN55I_MIXER_RCQ_STATUS, &status);
 	dbg_status = status;
 
@@ -1452,7 +1519,7 @@ static void sun55i_de_do_arm(struct sun55i_de *de)
 	 */
 	if (arm_busy_gate && (status & SUN55I_MIXER_RCQ_STATUS_BUSY)) {
 		dbg_arm_busy++;
-		return;
+		return 0;
 	}
 
 	/*
@@ -1471,13 +1538,14 @@ static void sun55i_de_do_arm(struct sun55i_de *de)
 		if (de->rcq_skips < 3) {
 			de->rcq_skips++;
 			dbg_arm_busy++;
-			return;
+			return 0;
 		}
 	}
 	de->rcq_skips = 0;
 
 	de->arm_pending = false;
 	de->armed_once = true;
+	de->stall_commits = 0;
 
