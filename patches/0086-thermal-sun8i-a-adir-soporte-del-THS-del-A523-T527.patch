From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Tue, 14 Jul 2026 01:08:59 +0200
Subject: [PATCH 086/106] =?UTF-8?q?thermal:=20sun8i:=20a=C3=B1adir=20sopor?=
 =?UTF-8?q?te=20del=20THS=20del=20A523=20(T527)?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

El A523 usa el mismo layout de registros del H616 pero con una función de
conversión a dos tramos y otra distribución de la calibración en el SID,
así que no vale el fallback al h616. Se añade la variante sun55i_a523_ths
(compatible propio "allwinner,sun55i-a523-ths") con su calc_temp (dos
tramos + el truco GPU->NPU del vendor) y su calibrate (4 sensores),
reutilizando init/irq_ack del h616.

Además el THS del A523 no cablea IRQ de dato-listo (el driver del BSP
sondea), así que se hace la interrupción opcional: si no hay, se cae al
polling del marco térmico (polling-delay) en vez de fallar el probe.

Fuente de verdad: bsp/drivers/thermal/sunxi_thermal.c (BSP Allwinner 5.15).

Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>
---
 drivers/thermal/sun8i_thermal.c | 134 ++++++++++++++++++++++++++++++--
 1 file changed, 127 insertions(+), 7 deletions(-)

diff --git a/drivers/thermal/sun8i_thermal.c b/drivers/thermal/sun8i_thermal.c
index 226747906..e0a03f378 100644
--- a/drivers/thermal/sun8i_thermal.c
+++ b/drivers/thermal/sun8i_thermal.c
@@ -114,6 +114,39 @@ static int sun50i_h5_calc_temp(struct ths_device *tmdev,
 		return -1590 * reg / 10 + 276000;
 }
 
+/*
+ * The A523 (sun55iw3) uses a two-segment linear transfer function instead of
+ * the single offset/scale one shared by most other SoCs, so it cannot fall
+ * back to the H616 formula. Values taken verbatim from the vendor driver
+ * (bsp/drivers/thermal/sunxi_thermal.c, sun55iw3_calc_temp()).
+ */
+#define SUN55I_A523_SENSOR_DATA_CODE	1991
+#define SUN55I_A523_OFFSET_LOW		(-2736)
+#define SUN55I_A523_SCALE_LOW		(-74)
+#define SUN55I_A523_OFFSET_HIGH		(-2825)
+#define SUN55I_A523_SCALE_HIGH		(-65)
+
+static int sun55i_a523_calc_temp_raw(int reg)
+{
+	if (reg > SUN55I_A523_SENSOR_DATA_CODE)
+		return (reg + SUN55I_A523_OFFSET_LOW) * SUN55I_A523_SCALE_LOW;
+
+	return (reg + SUN55I_A523_OFFSET_HIGH) * SUN55I_A523_SCALE_HIGH;
+}
+
+static int sun55i_a523_calc_temp(struct ths_device *tmdev, int id, int reg)
+{
+	/*
+	 * The GPU sensor (id 2) is unreliable on this silicon; the vendor
+	 * driver reads the NPU sensor (id 3) in its place, so do the same.
+	 */
+	if (id == 2)
+		regmap_read(tmdev->regmap,
+			    tmdev->chip->temp_data_base + 0x4 * 3, &reg);
+
+	return sun55i_a523_calc_temp_raw(reg);
+}
+
 static int sun8i_ths_get_temp(struct thermal_zone_device *tz, int *temp)
 {
 	struct tsensor *s = thermal_zone_device_priv(tz);
@@ -299,6 +332,73 @@ static int sun50i_h6_ths_calibrate(struct ths_device *tmdev,
 	return 0;
 }
 
+/*
+ * The A523 stores the factory-test temperature and per-sensor reference
+ * values in the SID at byte offsets 0x38, 0x3c and 0x44 (0x48 is only used by
+ * the DDR THS instance). The DT "calibration" cell covers 0x38..0x4c, so the
+ * u16 caldata array holds those three 32-bit words at indices [0,1], [2,3]
+ * and [6,7]. The bit layout and the +5000 fudge come from the vendor driver
+ * (bsp/drivers/thermal/sunxi_thermal.c, sun55iw3_ths1_calibrate()).
+ */
+#define SUN55I_A523_CAL_COM		5000
+
+static int sun55i_a523_ths_calibrate(struct ths_device *tmdev,
+				     u16 *caldata, int callen)
+{
+	struct device *dev = tmdev->dev;
+	u32 cal[3];
+	int i, ft_temp;
+
+	if (callen < 0x14)
+		return -EINVAL;
+
+	cal[0] = caldata[0] | (caldata[1] << 16);	/* SID 0x38 */
+	cal[1] = caldata[2] | (caldata[3] << 16);	/* SID 0x3c */
+	cal[2] = caldata[6] | (caldata[7] << 16);	/* SID 0x44 */
+
+	ft_temp = ((cal[1] << 8) | (cal[0] >> 24)) & FT_TEMP_MASK;
+	if (!ft_temp)
+		return 0;
+
+	for (i = 0; i < tmdev->chip->sensor_num; i++) {
+		int delta, cdata, offset, reg;
+
+		switch (i) {
+		case 0:
+			reg = (cal[1] >> 4) & TEMP_CALIB_MASK;
+			break;
+		case 1:
+			reg = (cal[1] >> 16) & TEMP_CALIB_MASK;
+			break;
+		case 2:
+			reg = cal[2] & TEMP_CALIB_MASK;
+			break;
+		case 3:
+			reg = (cal[2] >> 12) & TEMP_CALIB_MASK;
+			break;
+		default:
+			reg = 0;
+			break;
+		}
+
+		delta = (ft_temp * 100 + SUN55I_A523_CAL_COM -
+			 sun55i_a523_calc_temp_raw(reg)) / SUN55I_A523_SCALE_LOW;
+		cdata = CALIBRATE_DEFAULT - delta;
+		if (cdata & ~TEMP_CALIB_MASK) {
+			dev_warn(dev, "sensor%d is not calibrated.\n", i);
+			continue;
+		}
+
+		offset = (i % 2) * 16;
+		regmap_update_bits(tmdev->regmap,
+				   SUN50I_H6_THS_TEMP_CALIB + (i / 2 * 4),
+				   TEMP_CALIB_MASK << offset,
+				   cdata << offset);
+	}
+
+	return 0;
+}
+
 static int sun8i_ths_calibrate(struct ths_device *tmdev)
 {
 	struct nvmem_cell *calcell;
@@ -570,8 +670,14 @@ static int sun8i_ths_probe(struct platform_device *pdev)
 	if (ret)
 		return ret;
 
-	irq = platform_get_irq(pdev, 0);
-	if (irq < 0)
+	/*
+	 * Some SoCs (e.g. the A523) do not wire a dedicated data-ready
+	 * interrupt for the THS, matching the vendor driver which polls the
+	 * temperature registers. In that case fall back to the thermal core
+	 * polling (polling-delay) instead of failing to probe.
+	 */
+	irq = platform_get_irq_optional(pdev, 0);
+	if (irq < 0 && irq != -ENXIO)
 		return irq;
 
 	ret = tmdev->chip->init(tmdev);
@@ -587,11 +693,13 @@ static int sun8i_ths_probe(struct platform_device *pdev)
 	 * registered yet, we deffer the registration of the interrupt to
 	 * the end.
 	 */
-	ret = devm_request_threaded_irq(dev, irq, NULL,
-					sun8i_irq_thread,
-					IRQF_ONESHOT, "ths", tmdev);
-	if (ret)
-		return ret;
+	if (irq >= 0 && tmdev->chip->irq_ack) {
+		ret = devm_request_threaded_irq(dev, irq, NULL,
+						sun8i_irq_thread,
+						IRQF_ONESHOT, "ths", tmdev);
+		if (ret)
+			return ret;
+	}
 
 	return 0;
 }
@@ -709,6 +817,17 @@ static const struct ths_thermal_chip sun50i_h616_ths = {
 	.calc_temp = sun8i_ths_calc_temp,
 };
 
+static const struct ths_thermal_chip sun55i_a523_ths = {
+	.sensor_num = 4,
+	.has_bus_clk_reset = true,
+	.has_mod_clk = true,
+	.temp_data_base = SUN50I_H6_THS_TEMP_DATA,
+	.calibrate = sun55i_a523_ths_calibrate,
+	.init = sun50i_h6_thermal_init,
+	.irq_ack = sun50i_h6_irq_ack,
+	.calc_temp = sun55i_a523_calc_temp,
+};
+
 static const struct of_device_id of_ths_match[] = {
 	{ .compatible = "allwinner,sun8i-a83t-ths", .data = &sun8i_a83t_ths },
 	{ .compatible = "allwinner,sun8i-h3-ths", .data = &sun8i_h3_ths },
@@ -719,6 +838,7 @@ static const struct of_device_id of_ths_match[] = {
 	{ .compatible = "allwinner,sun50i-h6-ths", .data = &sun50i_h6_ths },
 	{ .compatible = "allwinner,sun20i-d1-ths", .data = &sun20i_d1_ths },
 	{ .compatible = "allwinner,sun50i-h616-ths", .data = &sun50i_h616_ths },
+	{ .compatible = "allwinner,sun55i-a523-ths", .data = &sun55i_a523_ths },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, of_ths_match);
-- 
