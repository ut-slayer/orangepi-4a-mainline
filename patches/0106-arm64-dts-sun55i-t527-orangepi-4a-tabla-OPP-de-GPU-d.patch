From de959a70cc36515878497703a0a4b2561bbd65c8 Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Tue, 14 Jul 2026 05:09:01 +0200
Subject: [PATCH 106/131] arm64: dts: sun55i-t527-orangepi-4a: tabla OPP de GPU
 (devfreq 150-600 MHz)

Los cinco puntos universales de la gpu_opp_table del BSP (150/200/300/400/
600 MHz; 648+ van por speed-bin y quedan fuera). Con operating-points-v2
en el nodo gpu, panfrost instancia devfreq con simple_ondemand: techo
600 MHz (+39% sobre los 432 MHz fijos que deja U-Boot) y bajada a
150 MHz en reposo.

Sin escalado de voltaje: el BSP pide 0.90V en todos los puntos y el rail
vdd-gpu-sys (AXP717 DCDC2) esta fijo a 0.92V, asi que cada OPP declara
0.92V y la transicion de voltaje es un no-op. El valor no puede omitirse:
el core OPP rechaza una tabla sin opp-microvolt cuando panfrost adjunta
el regulador mali-supply.
---
 .../dts/allwinner/sun55i-t527-orangepi-4a.dts | 43 +++++++++++++++++++
 1 file changed, 43 insertions(+)

diff --git a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
index 09964ccd5..baa444888 100644
--- a/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
+++ b/arch/arm64/boot/dts/allwinner/sun55i-t527-orangepi-4a.dts
@@ -331,6 +331,48 @@ opp-1800000000 {
 			opp-microvolt = <1150000>;
 		};
 	};
+
+	/*
+	 * GPU OPPs: the five speed-bin-independent points of the vendor
+	 * table (648 MHz and above are fused off on most bins, so they are
+	 * left out). All of them divide exactly from the fixed pll-periph0
+	 * outputs, so pll-gpu is never touched and powers down after the
+	 * first transition away from the U-Boot state (432 MHz on pll-gpu).
+	 *
+	 * The vendor table asks for 0.90 V on every point; this board's
+	 * vdd-gpu-sys rail (AXP717 DCDC2) is fixed at 0.92 V, so the OPPs
+	 * state 0.92 V and voltage transitions are no-ops. The value cannot
+	 * be dropped: the OPP core rejects a voltage-less table once
+	 * panfrost attaches the mali-supply regulator.
+	 */
+	gpu_opp_table: opp-table-gpu {
+		compatible = "operating-points-v2";
+
+		opp-150000000 {
+			opp-hz = /bits/ 64 <150000000>;
+			opp-microvolt = <920000>;
+		};
+
+		opp-200000000 {
+			opp-hz = /bits/ 64 <200000000>;
+			opp-microvolt = <920000>;
+		};
+
+		opp-300000000 {
+			opp-hz = /bits/ 64 <300000000>;
+			opp-microvolt = <920000>;
+		};
+
+		opp-400000000 {
+			opp-hz = /bits/ 64 <400000000>;
+			opp-microvolt = <920000>;
+		};
+
+		opp-600000000 {
+			opp-hz = /bits/ 64 <600000000>;
+			opp-microvolt = <920000>;
+		};
+	};
 };
 
 /* Little cluster (cpu0-3): AXP717 DCDC1 (vdd-cpul), up to 1.416 GHz. */
@@ -385,6 +427,7 @@ &ehci1 {
 
 &gpu {
 	mali-supply = <&reg_dcdc2>;
+	operating-points-v2 = <&gpu_opp_table>;
 	status = "okay";
 };
 
