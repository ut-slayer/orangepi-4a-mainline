From 7624a5cdff6785ebbd93c0b72580512bfba8229c Mon Sep 17 00:00:00 2001
From: Justin Suess <utilityemal77@gmail.com>
Date: Wed, 8 Jul 2026 18:08:55 +0200
Subject: [PATCH 035/130] drm/sun4i: sun8i_hdmi_phy: baja a debug el dump de
 registros Inno (minimyth2 2730)

Origen: serie display A523 de Justin Suess empaquetada en minimyth2
(warpme), backport a 6.18.36.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>

Parche original de la serie A523/H616 recopilada en minimyth2
(autoria git = autor original). Port y adaptacion a 6.18/T527:
Juan Manuel Lopez Carrillo (AurealNix) <juanmanuellopezcarrillo@gmail.com>.
---
 drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c b/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
index aa2f4b2a8..ced48559d 100644
--- a/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
+++ b/drivers/gpu/drm/sun4i/sun8i_hdmi_phy.c
@@ -957,7 +957,7 @@ static void sun55i_a523_inno_dump(struct sun8i_hdmi_phy *phy, const char *when)
 	fra = inno_rd32(phy, INNO_PLL_FRA);
 	dr0 = inno_rd32(phy, INNO_DR0);
 	rxs = inno_rd32(phy, INNO_RXSEN);
-	dev_info(phy->dev,
+	dev_dbg(phy->dev,
 		 "inno %s: ctl0=%08x pll0=%08x pll1=%08x pll2=%08x pll3=%08x fra=%08x dr0=%08x rxsen=%08x\n",
 		 when, ctl0, pll0, pll1, pll2, pll3, fra, dr0, rxs);
 }
@@ -1089,7 +1089,7 @@ static int sun55i_a523_hdmi_phy_init(struct dw_hdmi *hdmi, void *data,
 		dev_warn(phy->dev, "Inno PHY rxsense lock timeout\n");
 
 	sun55i_a523_inno_dump(phy, "post-rxsense");
-	dev_info(phy->dev, "inno: tmds=%ukHz mpll prepll_div=%08x clkdiv=%08x postpll=%08x\n",
+	dev_dbg(phy->dev, "inno: tmds=%ukHz mpll prepll_div=%08x clkdiv=%08x postpll=%08x\n",
 		 tmds_khz, mpll->prepll_div, mpll->prepll_clk_div, mpll->postpll);
 
 	sun55i_a523_inno_mpll_config(phy, mpll);
