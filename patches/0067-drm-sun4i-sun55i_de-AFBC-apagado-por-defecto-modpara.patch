From bf2801d45415406e536353985d5d7d20e357aab4 Mon Sep 17 00:00:00 2001
From: Juan Manuel Lopez Carrillo <juanmanuellopezcarrillo@gmail.com>
Date: Sun, 12 Jul 2026 15:01:02 +0200
Subject: [PATCH 067/106] drm/sun4i: sun55i_de: AFBC apagado por defecto
 (modparam afbc, decode WIP)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Veredicto visual del AFBD con contenido real (2026-07-12, kwin en la
imagen debootstrap): scanout AFBC = negro con cuadrados sueltos; LINEAR
= escritorio perfecto con vsync, mismo kernel y mismos buffers. La
programacion del bloque AFBD esta verificada por registros (en/seq/
blk_size/fmt/ytr/header todos como el diseno), asi que el bug esta en
la semantica de algun campo frente al BSP — pendiente de depurar con
patrones conocidos.

Hasta entonces no se anuncian los modifiers AFBC (IN_FORMATS solo
LINEAR y format_mod_supported los rechaza): cualquier compositor
negocia lineal sin hacks de entorno. Reactivable para depuracion con
sun8i-mixer afbc=1.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 drivers/gpu/drm/sun4i/sun55i_de.c      | 14 ++++++++++++++
 drivers/gpu/drm/sun4i/sun55i_de.h      |  1 +
 drivers/gpu/drm/sun4i/sun8i_ui_layer.c |  3 ++-
 3 files changed, 17 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/sun4i/sun55i_de.c b/drivers/gpu/drm/sun4i/sun55i_de.c
index 659a5e980..deee0f66f 100644
--- a/drivers/gpu/drm/sun4i/sun55i_de.c
+++ b/drivers/gpu/drm/sun4i/sun55i_de.c
@@ -996,11 +996,25 @@ static int sun55i_de_afbc_fmt_seq(u32 drm_fmt, u32 *seq)
 	return -EINVAL;
 }
 
+/*
+ * AFBC scanout via el AFBD: la programacion del bloque esta verificada por
+ * registros, pero el DECODE de contenido real sale mal (2026-07-12, kwin:
+ * AFBC = negro/cuadrados, LINEAR = escritorio perfecto — mismo kernel).
+ * Apagado por defecto hasta depurar la semantica contra el BSP; reactivar
+ * con sun8i-mixer afbc=1 para las sesiones de debug.
+ */
+bool sun55i_afbc_enable;
+module_param_named(afbc, sun55i_afbc_enable, bool, 0444);
+MODULE_PARM_DESC(afbc, "anunciar modifiers AFBC (decode AFBD en depuracion)");
+
 bool sun55i_de_afbc_mod_supported(u32 drm_fmt, u64 modifier)
 {
 	u32 seq;
 	unsigned int i;
 
+	if (!sun55i_afbc_enable)
+		return false;
+
 	if (sun55i_de_afbc_fmt_seq(drm_fmt, &seq))
 		return false;
 	for (i = 0; i < ARRAY_SIZE(sun55i_de_afbc_modifiers); i++)
diff --git a/drivers/gpu/drm/sun4i/sun55i_de.h b/drivers/gpu/drm/sun4i/sun55i_de.h
index f6ec1624e..edeb7af04 100644
--- a/drivers/gpu/drm/sun4i/sun55i_de.h
+++ b/drivers/gpu/drm/sun4i/sun55i_de.h
@@ -203,6 +203,7 @@ struct sun55i_de {
 	struct work_struct		fb_release_work;
 };
 
+extern bool sun55i_afbc_enable;	/* modparam afbc: anunciar AFBC (WIP) */
 bool sun55i_de_afbc_mod_supported(u32 drm_fmt, u64 modifier);
 int sun55i_de_init(struct sun8i_mixer *mixer);
 void sun55i_de_mode_set(struct sun8i_mixer *mixer,
diff --git a/drivers/gpu/drm/sun4i/sun8i_ui_layer.c b/drivers/gpu/drm/sun4i/sun8i_ui_layer.c
index cdfa5a467..c7461fee8 100644
--- a/drivers/gpu/drm/sun4i/sun8i_ui_layer.c
+++ b/drivers/gpu/drm/sun4i/sun8i_ui_layer.c
@@ -366,7 +366,8 @@ struct sun8i_layer *sun8i_ui_layer_init_one(struct drm_device *drm,
 
 	/* format_mod_supported necesita el mixer durante plane_init */
 	layer->mixer = mixer;
-	if (mixer->cfg->uses_rcq && index == 0)
+	/* AFBC solo si el decode AFBD esta en depuracion (modparam afbc=1) */
+	if (mixer->cfg->uses_rcq && index == 0 && sun55i_afbc_enable)
 		modifiers = sun55i_layer_modifiers;
 
 	/* possible crtcs are set later */
-- 
2.47.3

